<local:AttachmentsMessageScraperBase
    x:Class="LinkedDominatorUI.LDViews.Scraper.AttachmentsMessageScraper"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Control="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Scraper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{DynamicResource GabaritoSemiBold}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl
                Name="AttachmentsMessageHeader"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expander section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel>
                    <!--  -DateTimePicker  -->
                    <!--<StackPanel  Margin="5,15,0,5" Orientation="Horizontal" >
                        <CheckBox IsChecked="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}"/>
                        <Control:DateTimePicker Margin="5,5,5,0" IsEnabled="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}" Control:TextBoxHelper.UseFloatingWatermark="True"  SelectedDateFormat="Long"  Control:TextBoxHelper.Watermark="Start Date"
                                                SelectedDate="{Binding  MessageConversationScraperModel.StartDateForMessageConversation, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True}"                       />
                        <Label HorizontalAlignment="Center" VerticalAlignment="Center" Content="{DynamicResource LangKeyTo}" />
                        <Control:DateTimePicker Margin="5,5,5,0" IsEnabled="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}" Control:TextBoxHelper.UseFloatingWatermark="True"  SelectedDateFormat="Long"  Control:TextBoxHelper.Watermark="End Date"
                                                SelectedDate="{Binding MessageConversationScraperModel.EndDateForMessageConversation, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True}"   />
                    </StackPanel>-->
                    <!--  -MessageConversationSource  -->
                    <StackPanel>
                        <Label
                            Margin="5,10,0,0"
                            Content="Attachments Message Source"
                            FontWeight="Bold" />
                        <StackPanel Margin="15,15,0,5">
                            <RadioButton
                                Margin="5"
                                Content="All First Connections"
                                GroupName="MessageConversation"
                                IsChecked="{Binding MessageConversationScraperModel.IsAllFirstConnection}" />
                            <RadioButton
                                Margin="5"
                                Content="{DynamicResource LangKeyByCustomFirstConnectionList}"
                                GroupName="MessageConversation"
                                IsChecked="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList}" />

                            <StackPanel Margin="15,0,0,5" Visibility="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <customControl:InputBoxControl
                                    Margin="25,5"
                                    InputText="{Binding MessageConversationScraperModel.UrlInput}"
                                    SaveCommand="{Binding SaveCustomGroupListCommand}"
                                    WaterMarkText="Enter First Connection Url(s)" />
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>

                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">

                        <customControl:JobConfigControl JobConfiguration="{Binding MessageConversationScraperModel.JobConfiguration}" />
                    </Expander>
                    <!--  Other configuration  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True">
                        <StackPanel Orientation="Vertical">
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeyDownloadAttachments}"
                                IsChecked="{Binding MessageConversationScraperModel.IsDonwloadAttachments}" />
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeyDownloadAllConversations}"
                                IsChecked="{Binding MessageConversationScraperModel.IsDeleteAllConversations}" />
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeyDownloadAllAttachmnetinOneFolder}"
                                IsChecked="{Binding MessageConversationScraperModel.IsDownloadAllAttachmetinOneFolder}" />
                            <!--<StackPanel Orientation="Horizontal">
                                <CheckBox Margin="0,5,0,0" x:Name="TakeMininumConnectionConversation" IsChecked="{Binding MessageConversationScraperModel.IsTakeMinimumConnectionConversation}" Content="{DynamicResource LangKeyTakeMinimumConnectionConversation}" />
                                <Control:NumericUpDown IsEnabled="{Binding MessageConversationScraperModel.IsTakeMinimumConnectionConversation}"  Margin="10,5,0,0"  Maximum="1999" Minimum="0" Value="{Binding MessageConversationScraperModel.NumberOfConnectionConversations}" x:Name="TakeMininumConnectionConversationTextBox" />
                            </StackPanel>-->
                        </StackPanel>
                    </Expander>

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>

                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding MessageConversationScraperModel.IsChkSkipBlackListedUser}" />

                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding MessageConversationScraperModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding MessageConversationScraperModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding MessageConversationScraperModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>


            </ScrollViewer>
        </Grid>


        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="AttachmentsMessageFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Control:FlyoutsControl>
            <Control:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=AttachmentsMessageFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=AttachmentsMessageFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoScrapeAttachmentMessage}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Control:Flyout>
        </Control:FlyoutsControl>

    </Grid>
</local:AttachmentsMessageScraperBase>