<local:UserScraperBase
    x:Class="LinkedDominatorUI.LDViews.Scraper.UserScraper"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Scraper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="UserScraperBase"
    FontFamily="{DynamicResource GabaritoSemiBold}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl
                Name="UserScraperHeader"
                Grid.Row="0"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expender Section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <Expander
                        Margin="5"
                        Header="{DynamicResource LangKeySearchQuery}"
                        IsExpanded="True">
                        <customControl:SearchQueryControl
                            Name="UserScraperSearchControl"
                            AddQueryCommand="{Binding AddQueryCommand}"
                            CommandParameter="{Binding ElementName=UserScraperBase}"
                            CustomFilterCommand="{Binding CustomFilterCommand}"
                            DeleteMulipleCommand="{Binding DeleteMulipleCommand}"
                            DeleteQueryCommand="{Binding DeleteQueryCommand}"
                            ListQueryInfo="{Binding UserScraperModel.SavedQueries}"
                            ListQueryType="{Binding UserScraperModel.ListQueryType}" />

                    </Expander>
                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding UserScraperModel.JobConfiguration}" />
                    </Expander>

                    <!--  Other Configurations  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <RadioButton
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeyVisiting}"
                                GroupName="ViewType"
                                IsChecked="{Binding UserScraperModel.IsCheckedVisiting, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                            <RadioButton
                                Margin="10,5,0,0"
                                Content="{DynamicResource LangKeyWithoutVisiting}"
                                GroupName="ViewType"
                                IsChecked="{Binding UserScraperModel.IsCheckedWithoutVisiting, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />


                            <StackPanel Margin="10,5,0,0" Orientation="Horizontal">
                                <RadioButton
                                    Content="View Profile"
                                    GroupName="ViewType"
                                    IsChecked="{Binding UserScraperModel.IsViewProfileUsingEmbeddedBrowser, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                <TextBlock
                                    Padding="5,0"
                                    FontWeight="SemiBold"
                                    Text="*Not applicable for Joined Group Url" />
                            </StackPanel>

                            <CheckBox
                                Margin="10,5,0,0"
                                Content="{DynamicResource LangKeyUniqueOperations}"
                                IsChecked="{Binding UserScraperModel.IsUniqueOperationChecked}" />
                            <!--<RadioButton Content="{DynamicResource LangKeyVisitOnly}"
                                  Name="CheckBox_VisitOnly"
                                  Margin="10,5,0,0"
                                  IsChecked="{Binding IsCheckedVisitOnly,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                                  />-->
                            <StackPanel Margin="5,5,0,0" Orientation="Horizontal">
                                <CheckBox
                                    x:Name="EmailCheckbox"
                                    Margin="5,5,0,0"
                                    Content="{DynamicResource LangKeyMustHaveEmailid}"
                                    IsChecked="{Binding UserScraperModel.IsEmailExistCheckbox}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    Padding="5,0"
                                    FontWeight="SemiBold"
                                    Text="*Mostly use for 1st connection only" />
                            </StackPanel>

                            <StackPanel Margin="5,5,0,0" Orientation="Horizontal">
                                <CheckBox
                                    x:Name="PhoneNumberCheckbox"
                                    Margin="5,5,0,0"
                                    Content="{DynamicResource LangKeyMustHavePhoneNumber}"
                                    IsChecked="{Binding UserScraperModel.IsPhoneNumberExistCheckbox}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    Padding="5,0"
                                    FontWeight="SemiBold"
                                    Text="*Mostly use for 1st connection only" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!--  After User Filters Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyUserFilters}"
                        IsExpanded="True"
                        Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding UserScraperModel.LDUserFilterModel}" />
                    </Expander>

                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding UserScraperModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding UserScraperModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding UserScraperModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding UserScraperModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid
                Name="FooterGrid"
                Grid.Row="2"
                Margin="5,0">
                <customControl:FooterControl
                    x:Name="UserScraperFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=UserScraperFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=UserScraperFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoScrapeUsers}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>


    </Grid>
</local:UserScraperBase>