<local:WithdrawConnectionRequestBase
    x:Class="LinkedDominatorUI.LDViews.GrowConnection.WithdrawConnectionRequest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.GrowConnection"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">

            <customControl:HeaderControl
                Name="Header"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expander section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <!--  Requested user sources  -->
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeyRequestedUserSources}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyBySoftware}"
                            IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedBySoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyOutsideSoftware}"
                            IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedOutSideSoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyCustomUsersList}"
                            IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedLangKeyCustomUserList}" />
                        <customControl:InputBoxControl
                            x:Name="CustomUserListInputBox"
                            Margin="25,5"
                            InputText="{Binding WithdrawConnectionRequestModel.UrlInput}"
                            SaveCommand="{Binding SaveCustomUserListCommand}"
                            Visibility="{Binding WithdrawConnectionRequestModel.IsCheckedLangKeyCustomUserList, Converter={StaticResource BooleanToVisibilityConverter}}"
                            WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}" />
                    </StackPanel>
                    <!--<Label Content="{DynamicResource LangKeySourceType}" FontWeight="Bold" Margin="5,10,0,0"></Label>
                    <StackPanel  Margin="15,0,0,5" >
                        <CheckBox Content="{DynamicResource LangKeyPendingConnectionRequest}" Margin="5" IsChecked="{Binding IsCheckedPendingConnectionRequest}"/>
                        <CheckBox Content="{DynamicResource LangKeyAlreadyConnected}" Margin="5" IsChecked="{Binding IsCheckedAlreadyConnected}"/>
                    </StackPanel>-->
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeySourceFilter}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5" Orientation="Horizontal">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyRequestedBefore}"
                            IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedRequestedBefore}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedRequestedBefore}"
                            Minimum="0"
                            Value="{Binding WithdrawConnectionRequestModel.Days}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedRequestedBefore}"
                            Maximum="24"
                            Minimum="0"
                            Value="{Binding WithdrawConnectionRequestModel.Hours}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>

                    <!--  After JobConfiguration  Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding WithdrawConnectionRequestModel.JobConfiguration}" />
                    </Expander>

                    <!--  OtherConfigurations  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding WithdrawConnectionRequestModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Name="chkEnableAutoConnectionRequest"
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeyEnableAutoConnectionRequest}"
                                IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedEnableAutoConnectionRequest}" />
                            <StackPanel
                                Name="AutoEnableConnectionRequestSection"
                                Margin="15,0"
                                Orientation="Vertical"
                                Visibility="{Binding WithdrawConnectionRequestModel.IsCheckedEnableAutoConnectionRequest, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="{DynamicResource LangKeyWhenReaching}" IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestWhenLimitReach}" />
                                    <Controls:NumericUpDown
                                        Name="StartConnectionRequestWhenLimitReachStartValue"
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding WithdrawConnectionRequestModel.StartConnectionRequestWhenLimitReach.StartValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding WithdrawConnectionRequestModel.StartConnectionRequestWhenLimitReach.EndValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyConnectionWithdraws}" />
                                </StackPanel>
                                <CheckBox
                                    Margin="0,5,0,0"
                                    Content="{DynamicResource LangKeyWhenTheWithdrawConnectionRequestToolGetsTemporaryBlocked}"
                                    IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedWithdrawConnectionRequestToolGetsTemporaryBlocked}" />
                            </StackPanel>
                            <!--<StackPanel Margin="15,0" Visibility="{Binding WithdrawConnectionRequestModel.IsCheckedEnableAutoConnectionRequest,Converter={StaticResource BooleanToVisibilityConverter}}" Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyStartConnectionRequestToolBetween}"  Margin="0,5,0,0" IsChecked="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestBetween}"/>
                                <Controls:NumericUpDown Margin="5,5,5,0"   Minimum="1" Value="{Binding WithdrawConnectionRequestModel.StartConnectionRequestAfter.StartValue}"
                                                                        IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestBetween}" Name="StartConnectionRequestBetweenStartValue"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown Margin="5,5,5,0"  Minimum="1"
                                                                        Value="{Binding WithdrawConnectionRequestModel.StartConnectionRequestAfter.EndValue}" IsEnabled="{Binding WithdrawConnectionRequestModel.IsCheckedStartConnectionRequestBetween}"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyMinutesAfter}" />
                            </StackPanel>-->
                        </StackPanel>
                    </Expander>

                    <!--  Manage Blacklist Whitelist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistAndWhitelistUsers}"
                        Visibility="{Binding WithdrawConnectionRequestModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipWhitelistedUsers}"
                                IsChecked="{Binding WithdrawConnectionRequestModel.IsChkSkipWhiteListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding WithdrawConnectionRequestModel.IsChkSkipWhiteListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyUsePrivateWhitelist}"
                                    IsChecked="{Binding WithdrawConnectionRequestModel.IsChkUsePrivateWhiteList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyUseGroupWhitelist}"
                                    IsChecked="{Binding WithdrawConnectionRequestModel.IsChkUseGroupWhiteList}" />
                            </StackPanel>

                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeyAddToBlacklist}"
                                IsChecked="{Binding WithdrawConnectionRequestModel.IsChkAddToBlackList}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding WithdrawConnectionRequestModel.IsChkAddToBlackList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyAddToPrivateBlacklist}"
                                    IsChecked="{Binding WithdrawConnectionRequestModel.IsChkAddToPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyAddToGroupBlacklist}"
                                    IsChecked="{Binding WithdrawConnectionRequestModel.IsChkAddToGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>


                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="WithdrawConnectionRequestFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=WithdrawConnectionRequestFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=WithdrawConnectionRequestFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoWithdrawConnectionRequest}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>


    </Grid>
</local:WithdrawConnectionRequestBase>