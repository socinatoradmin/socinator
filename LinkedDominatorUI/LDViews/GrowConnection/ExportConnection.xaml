<local:ExportConnectionBase
    x:Class="LinkedDominatorUI.LDViews.GrowConnection.ExportConnection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.GrowConnection"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">

            <customControl:HeaderControl
                Name="ExportConnectionHeader"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expander section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <!--  Connected or requested user sources  -->
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeyConnectionSources}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyBySoftware}"
                            IsChecked="{Binding ExportConnectionModel.IsCheckedBySoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyOutsideSoftware}"
                            IsChecked="{Binding ExportConnectionModel.IsCheckedOutSideSoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyCustomUsersList}"
                            IsChecked="{Binding ExportConnectionModel.IsCheckedLangKeyCustomUserList}" />
                        <customControl:InputBoxControl
                            x:Name="CustomUserListInputBox"
                            Margin="25,5"
                            InputText="{Binding ExportConnectionModel.UrlInput}"
                            SaveCommand="{Binding SaveCustomUserListCommand}"
                            Visibility="{Binding ExportConnectionModel.IsCheckedLangKeyCustomUserList, Converter={StaticResource BooleanToVisibilityConverter}}"
                            WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}" />
                    </StackPanel>
                    <!--<Label Content="{DynamicResource LangKeySourceType}" FontWeight="Bold" Margin="5,10,0,0"></Label>
                    <StackPanel  Margin="15,0,0,5" >
                        <CheckBox Content="{DynamicResource LangKeyPendingConnectionRequest}" Margin="5" IsChecked="{Binding IsCheckedPendingConnectionRequest}"/>
                        <CheckBox Content="{DynamicResource LangKeyAlreadyConnected}" Margin="5" IsChecked="{Binding IsCheckedAlreadyConnected}"/>
                    </StackPanel>-->
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeySourceFilter}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5" Orientation="Horizontal">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyConnectedWithin}"
                            IsChecked="{Binding ExportConnectionModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding ExportConnectionModel.IsCheckedConnectedBefore}"
                            Minimum="0"
                            Value="{Binding ExportConnectionModel.Days}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding ExportConnectionModel.IsCheckedConnectedBefore}"
                            Maximum="24"
                            Minimum="0"
                            Value="{Binding ExportConnectionModel.Hours}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>


                    <!--  After JobConfiguration  Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding ExportConnectionModel.JobConfiguration}" />
                    </Expander>

                    <!--  Other Configuaration  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding ExportConnectionModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeyOnlyContactInfo}"
                                IsChecked="{Binding ExportConnectionModel.IsCheckedOnlyContactInfo, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                            <CheckBox
                                Name="chkFilenameFormat"
                                Margin="10,5,0,0"
                                Content="{DynamicResource LangKeyFilenameFormat}"
                                IsChecked="{Binding ExportConnectionModel.IsFilenameFormatChecked}" />
                            <customControl:InputBoxControl
                                x:Name="InputFilenameFormat"
                                Margin="30,5"
                                InputText="{Binding ExportConnectionModel.FilenameFormat, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                SaveCommand="{Binding SaveFileFormatCommand}"
                                Visibility="{Binding ExportConnectionModel.IsFilenameFormatChecked, Converter={StaticResource BooleanToVisibilityConverter}}"
                                WaterMarkText="{DynamicResource LangKeyWaterMarkTextFilenameFormat}" />
                            <CheckBox
                                Name="chkDownloadPdf"
                                Margin="10,5,0,0"
                                Content="{DynamicResource LangKeyDownloadPdf}"
                                IsChecked="{Binding ExportConnectionModel.IsCheckedDownloadPdf}" />
                            <StackPanel Margin="10,5,0,0" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource LangKeyWaitOnEachProfileBetween}" />
                                <Controls:NumericUpDown
                                    Name="WaitOnEachProfileStartValue"
                                    Margin="5,0,0,0"
                                    Minimum="1"
                                    Value="{Binding ExportConnectionModel.WaitOnEachProfileBetween.StartValue}" />
                                <Label
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown
                                    Name="WaitOnEachProfileEndValue"
                                    Minimum="1"
                                    Value="{Binding ExportConnectionModel.WaitOnEachProfileBetween.EndValue}" />
                                <Label VerticalAlignment="Center" Content="{DynamicResource LangKeyMinutes}" />
                            </StackPanel>

                            <CheckBox
                                Margin="10,5,0,0"
                                Content="{DynamicResource RecentConnections}"
                                IsChecked="{Binding ExportConnectionModel.IsCheckedRecentConnections}"
                                ToolTip="{DynamicResource ConnectedWithinDaysValueShouldBeLessThan}" />
                            <CheckBox
                                Margin="10,5,0,0"
                                Content="{DynamicResource LangKeyStopSchedulingInNoMoreData}"
                                IsChecked="{Binding ExportConnectionModel.IsStopScheduling}" />
                        </StackPanel>

                    </Expander>


                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding ExportConnectionModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding ExportConnectionModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding ExportConnectionModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding ExportConnectionModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding ExportConnectionModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>


                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="ExportConnectionFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=ExportConnectionFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=ExportConnectionFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoExportConnection}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>
</local:ExportConnectionBase>