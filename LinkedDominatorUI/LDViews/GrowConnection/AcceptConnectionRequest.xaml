<local:AcceptConnectionRequestBase
    x:Class="LinkedDominatorUI.LDViews.GrowConnection.AcceptConnectionRequest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.GrowConnection"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl
                Name="AcceptConnectionHeader"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expander section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel>
                    <!--  -AcceptConnectionRequestSource  -->
                    <StackPanel>
                        <Label
                            Margin="5,10,0,0"
                            Content="{DynamicResource LangKeyAcceptConnectionSource}"
                            FontWeight="Bold" />
                        <RadioButton
                            Margin="15,15,0,5"
                            Content="{DynamicResource LangKeyAllInvitations}"
                            GroupName="ConnectionRequest"
                            IsChecked="{Binding AcceptConnectionRequestModel.IsChkAllInvitations}" />

                        <Label
                            Margin="5,10,0,0"
                            Content="{DynamicResource LangKeyIgnoreConnectionSource}"
                            FontWeight="Bold" />
                        <RadioButton
                            Margin="15,15,0,5"
                            Content="{DynamicResource LangKeyAllInvitations}"
                            GroupName="ConnectionRequest"
                            IsChecked="{Binding AcceptConnectionRequestModel.IsChkIgnoreAllInvitations}" />

                        <!--<Label  Content="{DynamicResource LangKeySourceFilter}" FontWeight="Bold" Margin="5,10,0,0"/>
                            <StackPanel Orientation="Horizontal"  Margin="15,0,0,5">
                                <CheckBox Content="{DynamicResource LangKeyConnectionReqSentBefore}" Margin="5" IsChecked="{Binding IsUserFollowedBeforeChecked}"/>
                                <Controls:NumericUpDown Value="{Binding FollowedBeforeDay}" IsEnabled="{Binding IsUserFollowedBeforeChecked}"/>
                                <Label Content="{DynamicResource LangKeyDays}"/>
                                <Label Content="{DynamicResource LangKeyAnd}"/>
                                <Controls:NumericUpDown Value="{Binding FollowedBeforeHour}" Maximum="24" IsEnabled="{Binding IsUserFollowedBeforeChecked}"/>
                                <Label Content="{DynamicResource LangKeyHours}"/>
                            </StackPanel>-->
                    </StackPanel>

                    <!--  After JobConfiguration  Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding AcceptConnectionRequestModel.JobConfiguration}" />
                    </Expander>

                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding AcceptConnectionRequestModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding AcceptConnectionRequestModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding AcceptConnectionRequestModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding AcceptConnectionRequestModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding AcceptConnectionRequestModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>


                </StackPanel>

            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="AcceptConnectionFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=AcceptConnectionFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=AcceptConnectionFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoAcceptConnectionRequest}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>
</local:AcceptConnectionRequestBase>