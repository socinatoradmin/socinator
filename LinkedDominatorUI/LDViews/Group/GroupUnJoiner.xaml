<local:GroupUnJoinerBase
    x:Class="LinkedDominatorUI.LDViews.Group.GroupUnJoiner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Group"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{DynamicResource GabaritoSemiBold}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl
                Name="GroupUnJoinerHeader"
                Grid.Row="0"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expender Section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <!--  Group Sources  -->
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeyGroupSources}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyBySoftware}"
                            IsChecked="{Binding GroupUnJoinerModel.IsCheckedBySoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyOutsideSoftware}"
                            IsChecked="{Binding GroupUnJoinerModel.IsCheckedOutSideSoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyCustomGroupList}"
                            IsChecked="{Binding GroupUnJoinerModel.IsCheckedCustomGroupList}" />
                        <customControl:InputBoxControl
                            x:Name="CustomGroupListInputBox"
                            Margin="25,5"
                            InputText="{Binding GroupUnJoinerModel.UrlInput}"
                            SaveCommand="{Binding SaveCommand}"
                            Visibility="{Binding GroupUnJoinerModel.IsCheckedCustomGroupList, Converter={StaticResource BooleanToVisibilityConverter}}"
                            WaterMarkText="{DynamicResource LangKeyEnterYourGroupUrlS}" />
                    </StackPanel>

                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding GroupUnJoinerModel.JobConfiguration}" />
                    </Expander>

                    <!--  OtherConfigurations  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding GroupUnJoinerModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Name="chkEnableAutoGroupJoinert"
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeyEnableAutoGroupJoiner}"
                                IsChecked="{Binding GroupUnJoinerModel.IsCheckedEnableAutoGroupJoiner}" />
                            <StackPanel
                                Name="AutoEnableAutoGroupJoiner"
                                Margin="15,0"
                                Orientation="Vertical"
                                Visibility="{Binding GroupUnJoinerModel.IsCheckedEnableAutoGroupJoiner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyWhenReaching}"
                                        IsChecked="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerWhenLimitReach}" />
                                    <Controls:NumericUpDown
                                        Name="StartGroupJoinerStartValue"
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding GroupUnJoinerModel.StartGroupJoinerWhenLimitReach.StartValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding GroupUnJoinerModel.StartGroupJoinerWhenLimitReach.EndValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyGroupUnJoins}" />
                                </StackPanel>
                                <CheckBox
                                    Margin="0,5,0,0"
                                    Content="{DynamicResource LangKeyWhenTheGroupUnjoinerToolGetsTemporaryBlocked}"
                                    IsChecked="{Binding GroupUnJoinerModel.IsCheckedGroupUnJoinerToolGetsTemporaryBlocked}" />
                            </StackPanel>
                            <!--<StackPanel Margin="15,0" Visibility="{Binding GroupUnJoinerModel.IsCheckedEnableAutoGroupJoiner,Converter={StaticResource BooleanToVisibilityConverter}}" Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyStartGroupJoinerToolBetween}"  Margin="0,5,0,0" IsChecked="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerBetween}"/>
                                <Controls:NumericUpDown Margin="5,5,5,0"   Minimum="1" Value="{Binding GroupUnJoinerModel.StartGroupJoinerAfter.StartValue}"
                                                                        IsEnabled="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerBetween}" Name="StartGroupJoinerBetweenStartValue"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown Margin="5,5,5,0"  Minimum="1"
                                                                        Value="{Binding GroupUnJoinerModel.StartGroupJoinerAfter.EndValue}" IsEnabled="{Binding GroupUnJoinerModel.IsCheckedStartGroupJoinerBetween}"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyMinutesAfter}" />
                            </StackPanel>-->
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="GroupUnJoinerFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=GroupUnJoinerFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=GroupUnJoinerFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoUnjoinGroups}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>


    </Grid>
</local:GroupUnJoinerBase>