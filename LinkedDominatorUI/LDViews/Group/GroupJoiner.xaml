<local:GroupJoinerBase
    x:Class="LinkedDominatorUI.LDViews.Group.GroupJoiner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Group"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="GroupJoinerBase"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl
                Name="GroupJoinerHeader"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expender Section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <Expander
                        Margin="5"
                        Header="{DynamicResource LangKeySearchQuery}"
                        IsExpanded="True">
                        <customControl:SearchQueryControl
                            Name="GroupJoinerSearchControl"
                            AddQueryCommand="{Binding AddQueryCommand}"
                            CommandParameter="{Binding ElementName=GroupJoinerBase}"
                            CustomFilterCommand="{Binding CustomFilterCommand}"
                            DeleteMulipleCommand="{Binding DeleteMulipleCommand}"
                            DeleteQueryCommand="{Binding DeleteQueryCommand}"
                            ListQueryInfo="{Binding GroupJoinerModel.SavedQueries}"
                            ListQueryType="{Binding GroupJoinerModel.ListQueryType}" />
                    </Expander>
                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <customControl:JobConfigControl JobConfiguration="{Binding GroupJoinerModel.JobConfiguration}" />
                    </Expander>

                    <!--  OtherConfigurations  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding GroupJoinerModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Name="chkEnableAutoGroupUnJoinert"
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeyEnableAutoGroupUnjoiner}"
                                IsChecked="{Binding GroupJoinerModel.IsCheckedEnableAutoGroupUnJoiner}" />
                            <StackPanel
                                Name="AutoEnableAutoGroupUnJoiner"
                                Margin="15,0"
                                Orientation="Vertical"
                                Visibility="{Binding GroupJoinerModel.IsCheckedEnableAutoGroupUnJoiner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="{DynamicResource LangKeyWhenReaching}" IsChecked="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerWhenLimitReach}" />
                                    <Controls:NumericUpDown
                                        Name="StartGroupUnJoinerStartValue"
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding GroupJoinerModel.StartGroupUnJoinerWhenLimitReach.StartValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown
                                        Margin="5,5,5,0"
                                        IsEnabled="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerWhenLimitReach}"
                                        Minimum="1"
                                        Value="{Binding GroupJoinerModel.StartGroupUnJoinerWhenLimitReach.EndValue}" />
                                    <Label
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyPendingGroupJoinRequests}" />
                                </StackPanel>
                                <CheckBox
                                    Margin="0,5,0,0"
                                    Content="{DynamicResource LangKeyWhenTheGroupJoinerToolGetsTemporaryBlocked}"
                                    IsChecked="{Binding GroupJoinerModel.IsCheckedGroupJoinerToolGetsTemporaryBlocked}" />
                            </StackPanel>
                            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                <CheckBox
                                    Margin="0,5"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource LangKeyStopActivityOnContinuousFailsCount}"
                                    IsChecked="{Binding GroupJoinerModel.IsStopSendGroupJoinRequestOnFailed}" />
                                <Controls:NumericUpDown
                                    Margin="5"
                                    IsEnabled="{Binding GroupJoinerModel.IsStopSendGroupJoinRequestOnFailed}"
                                    Minimum="1"
                                    Value="{Binding GroupJoinerModel.StopSendGroupJoinRequestOnCount}" />
                            </StackPanel>
                            <!--<StackPanel Margin="15,0" Visibility="{Binding GroupJoinerModel.IsCheckedEnableAutoGroupUnJoiner,Converter={StaticResource BooleanToVisibilityConverter}}" Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyStartGroupUnjoinerToolBetween}"  Margin="0,5,0,0" IsChecked="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerBetween}"/>
                                <Controls:NumericUpDown Margin="5,5,5,0"   Minimum="1" Value="{Binding GroupJoinerModel.StartGroupUnJoinerAfter.StartValue}"
                                                                        IsEnabled="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerBetween}" Name="StartGroupUnJoinerBetweenStartValue"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown Margin="5,5,5,0"  Minimum="1"
                                                                        Value="{Binding GroupJoinerModel.StartGroupUnJoinerAfter.EndValue}" IsEnabled="{Binding GroupJoinerModel.IsCheckedStartGroupUnJoinerBetween}"/>
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyMinutesAfter}" />
                            </StackPanel>-->
                        </StackPanel>
                    </Expander>


                    <!--  After Blacklists Expender  -->
                    <!--<Expander  IsExpanded="True" Header="{DynamicResource LangKeyManageBlacklistedUsers}" Margin="5,5">
                            <StackPanel>
                                <StackPanel Margin="10,5">
                                    <CheckBox Content="{DynamicResource LangKeyPrivateBlacklists}"/>

                    -->
                    <!--<Button Content="{DynamicResource LangKeyAddPrivateBlacklists}" Background="{DynamicResource AccentBaseColorBrush}"  Height="25" VerticalContentAlignment="Center" Foreground="White" Margin="10,0"/>-->
                    <!--
                                </StackPanel>
                                <StackPanel  Margin="10,5">
                                    <CheckBox Content="{DynamicResource LangKeyGroupBlacklists}" />


                    -->
                    <!--<Button Background="{DynamicResource AccentBaseColorBrush}"  Content="{DynamicResource LangKeyAddGroupBlacklists}" Foreground="White" Margin="10,0"/>-->
                    <!--
                                </StackPanel>
                            </StackPanel>
                        </Expander>-->
                </StackPanel>
            </ScrollViewer>
        </Grid>


        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <customControl:FooterControl
                    x:Name="GroupJoinerFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />

            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=GroupJoinerFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <customControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=GroupJoinerFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoJoinGroups}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>

</local:GroupJoinerBase>