<local:GroupInviterBase x:Class="LinkedDominatorUI.LDViews.Group.GroupInviter"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Group"
                        mc:Ignorable="d"
                        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                        xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
                        xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
                        x:Name="GroupInviterBase">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <!--<Grid  VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.8*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="2*"/>-->
        <!--</Grid.RowDefinitions>
            <customControl:HeaderControl Grid.Row="0"  CampaignName="{Binding CampaignName}" Name="GroupInviterHeader"
                                              IsCampaignNameEditable="{Binding IsEditCampaignName}"
                                              IsCancelEditVisible="{Binding CancelEditVisibility}"
                                         CancelEditCommand="{Binding CancelEditCommand}"
                                         InfoCommand="{Binding InfoCommand}"/>-->
        <StackPanel VerticalAlignment="Top">
            <customControl:HeaderControl CampaignName="{Binding CampaignName}" Name="GroupInviterHeader"
                                         IsCampaignNameEditable="{Binding IsEditCampaignName}"
                                         IsCancelEditVisible="{Binding CancelEditVisibility}"
                                         CancelEditCommand="{Binding CancelEditCommand}"
                                         InfoCommand="{Binding InfoCommand}" />
        </StackPanel>

        <!--Expander section-->
        <Grid Margin="0,40,0,100" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <!--<customControl:SearchQueryControl Name="GroupInviterSearchControl" ListQueryType="{Binding ListQueryType}"  ListQueryInfo="{Binding SavedQueries}" 
                                                              AddQuery="GroupInviterSearchControl_OnAddQuery" CustomFilterChanged="GroupInviterSearchControl_OnCustomFilterChanged"/>-->
                    <Expander Header="{DynamicResource LangKeySearchQuery}" IsExpanded="True" Margin="5">
                        <customControl:SearchQueryControl Name="GroupInviterSearchControl"
                                                          ListQueryType="{Binding GroupInviterModel.ListQueryType}"
                                                          ListQueryInfo="{Binding GroupInviterModel.SavedQueries}"
                                                          AddQueryCommand="{Binding AddQueryCommand}"
                                                          CommandParameter="{Binding ElementName=GroupInviterBase}"
                                                          CustomFilterCommand="{Binding CustomFilterCommand}"
                                                          DeleteQueryCommand="{Binding DeleteQueryCommand}"
                                                          DeleteMulipleCommand="{Binding DeleteMulipleCommand}" />
                    </Expander>
                    <!-- After JobConfiguration  Expander-->
                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">
                        <customControl:JobConfigControl JobConfiguration="{Binding GroupInviterModel.JobConfiguration}" />
                    </Expander>


                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--<Grid Grid.Row="2" Margin="5,0" Name="FooterGrid">
                <customControl:FooterControl x:Name="GroupInviterFooter"
                                             CampaignManager="{Binding CampaignButtonContent}"
                                             NoOfAccountsSelected="{Binding SelectedAccountCount,Mode=TwoWay}" 
                                             SelectAccountChanged="GroupInviterFooter_OnSelectAccountChanged"
                                             CreateCampaignChanged="GroupInviterFooter_OnCreateCampaignChanged" 
                                             UpdateCampaignChanged="GroupInviterFooter_OnUpdateCampaignChanged"/>
            </Grid>-->

        <!--Create campaign and select account section-->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0" Name="FooterGrid">
                <customControl:FooterControl x:Name="GroupInviterFooter"
                                             CampaignManager="{Binding CampaignButtonContent}"
                                             NoOfAccountsSelected="{Binding SelectedAccountCount,Mode=TwoWay}"
                                             SelectAccountCommand="{Binding SelectAccountCommand}"
                                             CreateCampaignCommand="{Binding CreateCampaignCommand}" />

            </Grid>
        </StackPanel>


        <!--Help section-->
        <Controls:FlyoutsControl>
            <Controls:Flyout Header="{DynamicResource LangKeyModuleDescription }" Position="Right"
                             Visibility="Collapsed" Name="HelpFlyout" Theme="Accent" FontWeight="Bold"
                             Foreground="White" Width="300" BorderBrush="Black" BorderThickness="2"
                             IsOpen="{Binding IsOpen,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                             DataContext="{Binding ElementName=GroupInviterFooter,Path=DataContext}"
                             Background="{DynamicResource AccentBaseColorBrush}" FontSize="10">

                <customControl:HelpControl ModuleDescription="{DynamicResource LangKeyUserControlFollowerSliderText}"
                                           DataContext="{Binding ElementName=GroupInviterFooter,Path=DataContext}"
                                           VideoTutorial="{Binding VideoTutorialLink}"
                                           KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                                           ContactSupportLink="{Binding ContactSupportLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>
</local:GroupInviterBase>