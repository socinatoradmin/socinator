<local:CommentBase
    x:Class="LinkedDominatorUI.LDViews.Engage.Comment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DhCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Engage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="CommentBase"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DhCustomControl:HeaderControl
                Name="CommentHeader"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Filter section  -->
        <Grid Margin="0,40,0,60" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer x:Name="ScrollViewers">
                <StackPanel>
                    <Expander
                        Margin="5"
                        Header="{DynamicResource LangKeySearchQuery}"
                        IsExpanded="True">
                        <DhCustomControl:SearchQueryControl
                            Name="CommentSearchControl"
                            AddQueryCommand="{Binding AddQueryCommand}"
                            CommandParameter="{Binding ElementName=CommentBase}"
                            CustomFilterCommand="{Binding CustomFilterCommand}"
                            DeleteMulipleCommand="{Binding DeleteMulipleCommand}"
                            DeleteQueryCommand="{Binding DeleteQueryCommand}"
                            IsExpanded="{Binding IsExpanded, ElementName=CommentHeader}"
                            ListQueryInfo="{Binding CommentModel.SavedQueries}"
                            ListQueryType="{Binding CommentModel.ListQueryType}" />
                    </Expander>
                    <StackPanel Orientation="Vertical">
                        <!--  Comment manager Expander  -->

                        <Expander
                            Margin="5,5"
                            Header="{DynamicResource LangKeyManageComments}"
                            IsExpanded="True">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        Margin="32,5,0,0"
                                        Content="{DynamicResource LangKeySpintax}"
                                        IsChecked="{Binding CommentModel.IsChkSpintaxChecked}"
                                        ToolTip="{DynamicResource LangKeyCommentSpintaxFormat}" />
                                    <CheckBox
                                        Margin="20,5,0,0"
                                        Content="{DynamicResource LangKeyMultilineComment}"
                                        IsChecked="{Binding CommentModel.IsChkMultilineComment}" />
                                </StackPanel>

                                <DhCustomControl:CommentControl
                                    Name="CommentControl"
                                    AddCommentsCommand="{Binding AddCommentsCommand}"
                                    CommandParameter="{Binding ElementName=CommentControl}"
                                    Comments="{Binding CommentModel.ManageCommentModel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                <DhCustomControl:ManageComment LstManageCommentModel="{Binding CommentModel.LstDisplayManageCommentModel}" />
                            </StackPanel>
                        </Expander>

                        <!--  After JobConfiguration  Expander  -->
                        <Expander
                            Margin="5,5"
                            Header="{DynamicResource LangKeyJobConfiguration}"
                            IsExpanded="True">
                            <DhCustomControl:JobConfigControl JobConfiguration="{Binding CommentModel.JobConfiguration}" />
                        </Expander>


                        <!--  After User Filters Expander  -->

                        <Expander
                            Margin="5,5"
                            Header="{DynamicResource LangKeyUserFilters}"
                            IsExpanded="True"
                            Visibility="{Binding CommentModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding CommentModel.LDUserFilterModel}" />
                        </Expander>

                        <Expander
                            Margin="5,5"
                            Header="{DynamicResource LangKeyOtherConfigurations}"
                            Visibility="{Binding CommentModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <StackPanel Margin="10,0,0,5">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="{DynamicResource LangKeyMaximumNumberOfPostToBeCommentPerGroup}" IsChecked="{Binding CommentModel.IsNumberOfGroupPostToComment}" />
                                    <Controls:NumericUpDown
                                        Margin="5,0"
                                        IsEnabled="{Binding CommentModel.IsNumberOfGroupPostToComment}"
                                        Minimum="1"
                                        Value="{Binding CommentModel.MaxNumberOfPostPerGroupToComment}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="{DynamicResource LangKeyMaximumNumberOfPostToBeCommentPerUser}" IsChecked="{Binding CommentModel.IsNumberOfPostToComment}" />
                                    <Controls:NumericUpDown
                                        Margin="5,0"
                                        IsEnabled="{Binding CommentModel.IsNumberOfPostToComment}"
                                        Minimum="1"
                                        Value="{Binding CommentModel.MaxNumberOfPostPerUserToComment}" />
                                </StackPanel>

                                <CheckBox
                                    Name="ChkUniqueUserAccount"
                                    Margin="0,0,10,0"
                                    Content="{DynamicResource LangKeyPerformActionOnPostsOfUniqueUserFromEachAccountsInThisCampaign}"
                                    FontWeight="SemiBold"
                                    IsChecked="{Binding CommentModel.IschkUniqueUserForAccount}" />
                                <CheckBox
                                    Name="ChkUniqueUserCampaign"
                                    Margin="0,5,10,0"
                                    Content="{DynamicResource LangKeyPerformActionOnPostsOfUniqueUserFromAllAccountsInThisCampaign}"
                                    FontWeight="SemiBold"
                                    IsChecked="{Binding CommentModel.IschkUniqueUserForCampaign}" />
                                <CheckBox
                                    Name="ChkUniquePostCampaign"
                                    Margin="0,5,10,0"
                                    Content="{DynamicResource LangKeyPerformActionOnUniquePostFromAllAccountsInThisCampaign}"
                                    FontWeight="SemiBold"
                                    IsChecked="{Binding CommentModel.IschkUniquePostForCampaign}" />
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        Name="ChkUpvoteFromRandomPercentageOfAccount"
                                        Margin="0,5,10,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyPerformActionFromRandom}"
                                        FontWeight="SemiBold"
                                        IsChecked="{Binding CommentModel.IsPerformActionFromRandomPercentageOfAccounts}" />
                                    <Controls:NumericUpDown
                                        Margin="0,5,0,0"
                                        IsEnabled="{Binding CommentModel.IsPerformActionFromRandomPercentageOfAccounts}"
                                        Minimum="10"
                                        Value="{Binding CommentModel.PerformActionFromRandomPercentage.StartValue}" />
                                    <Label
                                        Margin="0,5,0,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown
                                        Margin="0,5,0,0"
                                        IsEnabled="{Binding CommentModel.IsPerformActionFromRandomPercentageOfAccounts}"
                                        Minimum="{Binding CommentModel.PerformActionFromRandomPercentage.StartValue}"
                                        Value="{Binding CommentModel.PerformActionFromRandomPercentage.EndValue}" />
                                    <Label
                                        Margin="0,5,0,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyPercentageOfSelectedAccounts}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        Name="ChkDelayBetweenUpvotesOnSamePost"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyKeepDelayBetween}"
                                        FontWeight="SemiBold"
                                        IsChecked="{Binding CommentModel.EnableDelayBetweenPerformingActionOnSamePost}" />
                                    <Controls:NumericUpDown
                                        Margin="0,5,0,0"
                                        IsEnabled="{Binding CommentModel.EnableDelayBetweenPerformingActionOnSamePost}"
                                        Minimum="10"
                                        Value="{Binding CommentModel.DelayBetweenPerformingActionOnSamePost.StartValue}" />
                                    <Label
                                        Margin="0,5,0,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown
                                        Margin="0,5,0,0"
                                        IsEnabled="{Binding CommentModel.EnableDelayBetweenPerformingActionOnSamePost}"
                                        Minimum="{Binding CommentModel.DelayBetweenPerformingActionOnSamePost.StartValue}"
                                        Value="{Binding CommentModel.DelayBetweenPerformingActionOnSamePost.EndValue}" />
                                    <Label
                                        Margin="0,5,0,0"
                                        VerticalAlignment="Center"
                                        Content="{DynamicResource LangKeySecondsWhenPerformingActionOnASpecificPost}" />
                                </StackPanel>

                            </StackPanel>
                        </Expander>

                        <!--  Manage Blacklist Users  Expander  -->

                        <Expander
                            Margin="5,5"
                            Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                            Visibility="{Binding CommentModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <CheckBox
                                    Margin="10,5"
                                    Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                    IsChecked="{Binding CommentModel.IsChkSkipBlackListedUser}" />
                                <StackPanel
                                    Margin="25,5"
                                    Orientation="Horizontal"
                                    Visibility="{Binding CommentModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <CheckBox
                                        Margin="5,0"
                                        Content="{DynamicResource LangKeyPrivateBlacklist}"
                                        IsChecked="{Binding CommentModel.IsChkPrivateBlackList}" />
                                    <CheckBox
                                        Margin="5,0"
                                        Content="{DynamicResource LangKeyGroupBlacklist}"
                                        IsChecked="{Binding CommentModel.IsChkGroupBlackList}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>


                        <!--  After Post Filter Expander  -->

                        <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=CommentHeader}" Header="{DynamicResource LangKeyPostFilter}" Margin="5,5">
                            <LdCustomControl:PostFilterControl PostFilter="{Binding PostFilterModel}"/>
                        </Expander>-->

                        <!--  After Comment Action Expander  -->

                        <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=CommentHeader}" Header="{DynamicResource LangKeyAfterCommentAction}" Margin="5,5" >

                            <StackPanel>
                                <CheckBox Content="{DynamicResource LangKeyEnableDynamicMentions}" Margin="5,5" IsChecked="{Binding IsChkAfterCommentAction}" />

                                <CheckBox Content="{DynamicResource LangKeyMentionNonExistingUsers}" Margin="5,5" IsChecked="{Binding IsChkMentionNonExistingUsers}"/>

                                <StackPanel Orientation="Horizontal" Margin="5,5">
                                    <CheckBox Content="{DynamicResource LangKeyMentionBetween}" IsChecked="{Binding IsChkMentionRandomUsers}"  />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding IsChkMentionRandomUsers}" Value="{Binding RandomlyGeneratedUsers.StartValue}" Name="IsChkMentionRandomUserStartValue"
                                                            Minimum="0"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyAnd}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding IsChkMentionRandomUsers}" Value="{Binding RandomlyGeneratedUsers.EndValue}" Minimum="{Binding RandomlyGeneratedUsers.StartValue}" />
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyRandomlyGeneratedUsers}" />
                                </StackPanel>
                                <CheckBox Content="{DynamicResource LangKeyAllowMultipleCommentsOnSamePost}" Margin="5,5" IsChecked="{Binding IsChkMultipleCommentsOnSamePost}" />
                                <CheckBox Content="{DynamicResource LangKeyAllowCommentsOnOwnPosts}" Margin="5,5" IsChecked="{Binding IsChkCommentsOnOwnPost}"/>
                                <CheckBox Content="{DynamicResource LangKeyLikePostAfterComment}" Margin="5,5" IsChecked="{Binding IsChkLikePostAfterComment}"/>
                                <CheckBox Content="{DynamicResource LangKeyFollowUserAfterComment}" Margin="5,5" IsChecked="{Binding IsChkFollowUserAfterComment}"/>
                                <CheckBox Content="{DynamicResource LangKeyRemovePoorQualitySources}" Margin="5,5" IsChecked="{Binding IsChkRemovePoorQuality}"/>
                                <StackPanel Orientation="Horizontal" Margin="5,5">
                                    <CheckBox Content="{DynamicResource LangKeyRemoveSourcesIfFollowBackRatioIsLowerThan}" IsChecked="{Binding IsChkRemoveIfFollowBackRatioLimit}"/>
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding IsChkRemoveIfFollowBackRatioLimit}" Value="{Binding RemoveIfMinFollowBackRatioValue}"
                                                            Minimum="0"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyAfter}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0"  IsEnabled="{Binding IsChkRemoveIfFollowBackRatioLimit}" Value="{Binding RemoveIfFollowBackRatioAfterCommentValue}" />
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyComments}" />

                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5,5">
                                    <CheckBox Content="{DynamicResource LangKeySuspendToolWhenGotTemporaryBlockFor}" IsChecked="{Binding IsChkSuspendToolWhenGotBlock}"/>
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding IsChkSuspendToolWhenGotBlock}" Value="{Binding SuspendToolWhenGotBlockedValue}"
                                                            Minimum="0"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyMinutes}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>-->


                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Name="FooterGrid" Margin="5,0">
                <DhCustomControl:FooterControl
                    x:Name="CommentFooter"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=CommentFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DhCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=CommentFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoComment}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>
</local:CommentBase>