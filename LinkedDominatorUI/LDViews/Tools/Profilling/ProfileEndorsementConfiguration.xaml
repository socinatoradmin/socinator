<local:ProfileEndorsementConfigurationBase
    x:Class="LinkedDominatorUI.LDViews.Tools.Profilling.ProfileEndorsementConfiguration"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.Profilling"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    mc:Ignorable="d"
    x:Name="profileEndorsementConfiguration"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand,ElementName=profileEndorsementConfiguration}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Name="MainGrid">
        <StackPanel>
            <customControl:AccountGrowthModeHeader x:FieldModifier="public"
                                                   Name="AccountGrowthHeader"
                                                   VideoTutorialLink="{Binding VideoTutorialLink}"
                                                   VerticalAlignment="Top"
                                                   SelectionChangedCommand="{Binding SelectionChangedCommand,ElementName=profileEndorsementConfiguration}"
                                                   SaveCommand="{Binding SaveConfigurationsCommand}" />
        </StackPanel>

        <Grid Margin="0,40,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="{DynamicResource LangKeyStatus}" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,10,0" />
                        <Controls:ToggleSwitch x:Name="TglStatus"
                                               IsChecked="{Binding ProfileEndorsementModel.IsAccountGrowthActive}"
                                               OnLabel="Active﻿"
                                               OffLabel="Stopped﻿"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction
                                        Command="{Binding StatusChangedCommand,ElementName=profileEndorsementConfiguration}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Controls:ToggleSwitch>
                    </StackPanel>
                    <!--Connection Sources-->
                    <Label Content="{DynamicResource LangKeyConnectionSources}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyBySoftware}" Margin="5"
                                  IsChecked="{Binding ProfileEndorsementModel.IsCheckedBySoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyOutsideSoftware}" Margin="5"
                                  IsChecked="{Binding ProfileEndorsementModel.IsCheckedOutSideSoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyCustomUsersList}" Margin="5"
                                  IsChecked="{Binding ProfileEndorsementModel.IsCheckedLangKeyCustomUserList}" />
                        <customControl:InputBoxControl Margin="25,5" x:Name="CustomUserListInputBox"
                                                       InputText="{Binding ProfileEndorsementModel.UrlInput}"
                                                       SaveCommand="{Binding SaveCustomUserListCommand}"
                                                       WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}"
                                                       Visibility="{Binding ProfileEndorsementModel.IsCheckedLangKeyCustomUserList,Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                    <Label Content="{DynamicResource LangKeyEndorsementCriteria}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Margin="15,0,0,5" Orientation="Horizontal">
                        <Label Content="{DynamicResource LangKeyNumberOfSkillsToBeEndorsed}" />
                        <Controls:NumericUpDown Minimum="1"
                                                Value="{Binding ProfileEndorsementModel.NumberOfSkillsToBeEndorsed}"
                                                IsEnabled="True" />
                    </StackPanel>

                    <StackPanel Margin="15,0,0,5" Orientation="Horizontal">
                        <CheckBox Content="{DynamicResource LangKeyConnectedWithin}"
                                  IsChecked="{Binding ProfileEndorsementModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown Value="{Binding ProfileEndorsementModel.Days}" Minimum="0"
                                                IsEnabled="{Binding ProfileEndorsementModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown Value="{Binding ProfileEndorsementModel.Hours}" Minimum="0"
                                                Maximum="24"
                                                IsEnabled="{Binding ProfileEndorsementModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>

                    <!-- After JobConfiguration  Expender-->

                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">
                        <customControl:JobConfigControl
                            JobConfiguration="{Binding ProfileEndorsementModel.JobConfiguration}" />
                    </Expander>

                    <!-- After User Filters Expender-->

                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyUserFilters}" Margin="5,5"
                              Visibility="{Binding IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl"
                                                            LDUserFilter="{Binding ProfileEndorsementModel.LDUserFilterModel}" />
                    </Expander>

                    <!--Manage Blacklist Users  expander-->

                    <Expander Header="{DynamicResource LangKeyManageBlacklistedUsers}" Margin="5,5"
                              Visibility="{Binding ProfileEndorsementModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LangKeySkipBlacklistedUsers}" Margin="10,5"
                                      IsChecked="{Binding ProfileEndorsementModel.IsChkSkipBlackListedUser}" />
                            <StackPanel Margin="25,5"
                                        Visibility="{Binding ProfileEndorsementModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyPrivateBlacklist}" Margin="5,0"
                                          IsChecked="{Binding ProfileEndorsementModel.IsChkPrivateBlackList}" />
                                <CheckBox Content="{DynamicResource LangKeyGroupBlacklist}" Margin="5,0"
                                          IsChecked="{Binding ProfileEndorsementModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</local:ProfileEndorsementConfigurationBase>