<local:ExportConnectionConfigurationBase
    x:Class="LinkedDominatorUI.LDViews.Tools.GrowConnection.ExportConnectionConfiguration"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.GrowConnection"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:customControl1="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    x:Name="exportConnectionConfiguration"
    mc:Ignorable="d"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand,ElementName=exportConnectionConfiguration}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Name="MainGrid">
        <StackPanel>
            <customControl:AccountGrowthModeHeader x:FieldModifier="public"
                                                   Name="AccountGrowthHeader"
                                                   VideoTutorialLink="{Binding VideoTutorialLink}"
                                                   VerticalAlignment="Top"
                                                   SelectionChangedCommand="{Binding SelectionChangedCommand,ElementName=exportConnectionConfiguration}"
                                                   SaveCommand="{Binding SaveConfigurationsCommand}" />
        </StackPanel>

        <Grid Margin="0,40,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="{DynamicResource LangKeyStatus}" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,10,0" />
                        <Controls:ToggleSwitch x:Name="TglStatus"
                                               IsChecked="{Binding ExportConnectionModel.IsAccountGrowthActive}"
                                               OnLabel="Active﻿"
                                               OffLabel="Stopped﻿"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction
                                        Command="{Binding StatusChangedCommand,ElementName=exportConnectionConfiguration}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Controls:ToggleSwitch>
                    </StackPanel>
                    <!--Connected or requested user sources-->
                    <Label Content="{DynamicResource LangKeyConnectionSources}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyBySoftware}" Margin="5"
                                  IsChecked="{Binding ExportConnectionModel.IsCheckedBySoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyOutsideSoftware}" Margin="5"
                                  IsChecked="{Binding ExportConnectionModel.IsCheckedOutSideSoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyCustomUsersList}" Margin="5"
                                  IsChecked="{Binding ExportConnectionModel.IsCheckedLangKeyCustomUserList}" />
                        <customControl:InputBoxControl Margin="25,5" x:Name="CustomUserListInputBox"
                                                       InputText="{Binding ExportConnectionModel.UrlInput}"
                                                       SaveCommand="{Binding SaveCustomUserListCommand}"
                                                       WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}"
                                                       Visibility="{Binding ExportConnectionModel.IsCheckedLangKeyCustomUserList,Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                    <!--<Label Content="{DynamicResource LangKeySourceType}" FontWeight="Bold" Margin="5,10,0,0"></Label>
                    <StackPanel  Margin="15,0,0,5" >
                        <CheckBox Content="{DynamicResource LangKeyPendingConnectionRequest}" Margin="5" IsChecked="{Binding IsCheckedPendingConnectionRequest}"/>
                        <CheckBox Content="{DynamicResource LangKeyAlreadyConnected}" Margin="5" IsChecked="{Binding IsCheckedAlreadyConnected}"/>
                    </StackPanel>-->
                    <Label Content="{DynamicResource LangKeySourceFilter}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyConnectedWithin}" Margin="5"
                                  IsChecked="{Binding ExportConnectionModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown Value="{Binding ExportConnectionModel.Days}" Minimum="0"
                                                IsEnabled="{Binding ExportConnectionModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown Value="{Binding ExportConnectionModel.Hours}" Minimum="0" Maximum="24"
                                                IsEnabled="{Binding ExportConnectionModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>


                    <!-- After JobConfiguration  Expender-->

                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">
                        <customControl:JobConfigControl
                            JobConfiguration="{Binding ExportConnectionModel.JobConfiguration}" />
                    </Expander>

                    <!--Other Configuaration-->
                    <Expander Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5" IsExpanded="True"
                              Visibility="{Binding ExportConnectionModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox Margin="10,0,0,0"
                                      Content="{DynamicResource LangKeyOnlyContactInfo}"
                                      IsChecked="{Binding ExportConnectionModel.IsCheckedOnlyContactInfo,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" />
                            <CheckBox Content="{DynamicResource LangKeyFilenameFormat}" Margin="10,5,0,0"
                                      Name="chkFilenameFormat"
                                      IsChecked="{Binding ExportConnectionModel.IsFilenameFormatChecked}" />
                            <customControl:InputBoxControl
                                Margin="30,5"
                                x:Name="InputFilenameFormat"
                                SaveCommand="{Binding SaveFileFormatCommand}"
                                WaterMarkText="{DynamicResource LangKeyWaterMarkTextFilenameFormat}"
                                InputText="{Binding ExportConnectionModel.FilenameFormat,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"
                                Visibility="{Binding ExportConnectionModel.IsFilenameFormatChecked,Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <CheckBox Content="{DynamicResource LangKeyDownloadPdf}" Margin="10,5,0,0"
                                      Name="chkDownloadPdf" IsChecked="{Binding IsCheckedDownloadPdf}" />
                            <StackPanel Orientation="Horizontal" Margin="10,5,0,0">
                                <TextBlock VerticalAlignment="Center"
                                           Text="{StaticResource LangKeyWaitOnEachProfileBetween}" />
                                <Controls:NumericUpDown Minimum="1" Name="WaitOnEachProfileStartValue"
                                                        Value="{Binding ExportConnectionModel.WaitOnEachProfileBetween.StartValue}" />
                                <Label HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown Minimum="1" Name="WaitOnEachProfileEndValue"
                                                        Value="{Binding ExportConnectionModel.WaitOnEachProfileBetween.EndValue}" />
                                <Label VerticalAlignment="Center" Content="{DynamicResource LangKeyMinutes}" />
                            </StackPanel>

                            <CheckBox Content="{DynamicResource RecentConnections}" Margin="10,5,0,0"
                                      ToolTip="{DynamicResource ConnectedWithinDaysValueShouldBeLessThan}"
                                      IsChecked="{Binding ExportConnectionModel.IsCheckedRecentConnections}" />

                            <CheckBox Content="{DynamicResource LangKeyStopSchedulingInNoMoreData}" Margin="10,5,0,0"
                                      IsChecked="{Binding ExportConnectionModel.IsStopScheduling}" />
                        </StackPanel>
                    </Expander>
                    <!--Manage Blacklist Users  expander-->

                    <Expander Header="{DynamicResource LangKeyManageBlacklistedUsers}" Margin="5,5"
                              Visibility="{Binding ExportConnectionModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LangKeySkipBlacklistedUsers}" Margin="10,5"
                                      IsChecked="{Binding ExportConnectionModel.IsChkSkipBlackListedUser}" />
                            <StackPanel Margin="25,5"
                                        Visibility="{Binding ExportConnectionModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyPrivateBlacklist}" Margin="5,0"
                                          IsChecked="{Binding ExportConnectionModel.IsChkPrivateBlackList}" />
                                <CheckBox Content="{DynamicResource LangKeyGroupBlacklist}" Margin="5,0"
                                          IsChecked="{Binding ExportConnectionModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</local:ExportConnectionConfigurationBase>