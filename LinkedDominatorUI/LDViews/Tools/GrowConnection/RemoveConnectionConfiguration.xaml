<local:RemoveConnectionConfigurationBase
    x:Class="LinkedDominatorUI.LDViews.Tools.GrowConnection.RemoveConnectionConfiguration"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.GrowConnection"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:customControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:customControl1="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    mc:Ignorable="d"
    x:Name="removeConnectionConfiguration"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand,ElementName=removeConnectionConfiguration}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Name="MainGrid">
        <StackPanel>
            <customControl:AccountGrowthModeHeader x:FieldModifier="public"
                                                   Name="AccountGrowthHeader"
                                                   VerticalAlignment="Top"
                                                   SelectionChangedCommand="{Binding SelectionChangedCommand,ElementName=removeConnectionConfiguration}"
                                                   SaveCommand="{Binding SaveConfigurationsCommand}" />
        </StackPanel>

        <Grid Margin="0,40,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="{DynamicResource LangKeyStatus}" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,10,0" />
                        <Controls:ToggleSwitch x:Name="TglStatus"
                                               IsChecked="{Binding RemoveConnectionModel.IsAccountGrowthActive}"
                                               OnLabel="Active﻿"
                                               OffLabel="Stopped﻿"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction
                                        Command="{Binding StatusChangedCommand,ElementName=removeConnectionConfiguration}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Controls:ToggleSwitch>
                    </StackPanel>
                    <!--Connected or requested user sources-->
                    <Label Content="{DynamicResource LangKeyConnectionSources}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyBySoftware}" Margin="5"
                                  IsChecked="{Binding RemoveConnectionModel.IsCheckedBySoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyOutsideSoftware}" Margin="5"
                                  IsChecked="{Binding RemoveConnectionModel.IsCheckedOutSideSoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyCustomUsersList}" Margin="5"
                                  IsChecked="{Binding RemoveConnectionModel.IsCheckedLangKeyCustomUserList}" />
                        <customControl:InputBoxControl Margin="25,5" x:Name="CustomUserListInputBox"
                                                       InputText="{Binding RemoveConnectionModel.UrlInput}"
                                                       SaveCommand="{Binding SaveCustomUserListCommand}"
                                                       WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}"
                                                       Visibility="{Binding RemoveConnectionModel.IsCheckedLangKeyCustomUserList,Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                    <!--<Label Content="{DynamicResource LangKeySourceType}" FontWeight="Bold" Margin="5,10,0,0"></Label>
                    <StackPanel  Margin="15,0,0,5" >
                        <CheckBox Content="{DynamicResource LangKeyPendingConnectionRequest}" Margin="5" IsChecked="{Binding IsCheckedPendingConnectionRequest}"/>
                        <CheckBox Content="{DynamicResource LangKeyAlreadyConnected}" Margin="5" IsChecked="{Binding IsCheckedAlreadyConnected}"/>
                    </StackPanel>-->
                    <Label Content="{DynamicResource LangKeySourceFilter}" FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyConnectedBefore}" Margin="5"
                                  IsChecked="{Binding RemoveConnectionModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown Value="{Binding RemoveConnectionModel.Days}" Minimum="0"
                                                IsEnabled="{Binding RemoveConnectionModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown Value="{Binding RemoveConnectionModel.Hours}" Minimum="0" Maximum="24"
                                                IsEnabled="{Binding RemoveConnectionModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>


                    <!-- After JobConfiguration  Expender-->

                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">
                        <customControl:JobConfigControl
                            JobConfiguration="{Binding RemoveConnectionModel.JobConfiguration}" />
                    </Expander>

                    <!--Manage Blacklist Whitelist Users  expander-->

                    <Expander Header="{DynamicResource LangKeyManageBlacklistAndWhitelistUsers}" Margin="5,5"
                              Visibility="{Binding RemoveConnectionModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox Content="{DynamicResource LangKeySkipWhitelistedUsers}" Margin="10,5"
                                      IsChecked="{Binding RemoveConnectionModel.IsChkSkipWhiteListedUser}" />
                            <StackPanel Margin="25,5"
                                        Visibility="{Binding RemoveConnectionModel.IsChkSkipWhiteListedUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyUsePrivateWhitelist}" Margin="5,0"
                                          IsChecked="{Binding RemoveConnectionModel.IsChkUsePrivateWhiteList}" />
                                <CheckBox Content="{DynamicResource LangKeyUseGroupWhitelist}" Margin="5,0"
                                          IsChecked="{Binding RemoveConnectionModel.IsChkUseGroupWhiteList}" />
                            </StackPanel>

                            <CheckBox Content="{DynamicResource LangKeyAddToBlacklist}" Margin="10,5"
                                      IsChecked="{Binding RemoveConnectionModel.IsChkAddToBlackList}" />
                            <StackPanel Margin="25,5"
                                        Visibility="{Binding RemoveConnectionModel.IsChkAddToBlackList, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyAddToPrivateBlacklist}" Margin="5,0"
                                          IsChecked="{Binding RemoveConnectionModel.IsChkAddToPrivateBlackList}" />
                                <CheckBox Content="{DynamicResource LangKeyAddToGroupBlacklist}" Margin="5,0"
                                          IsChecked="{Binding RemoveConnectionModel.IsChkAddToGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</local:RemoveConnectionConfigurationBase>