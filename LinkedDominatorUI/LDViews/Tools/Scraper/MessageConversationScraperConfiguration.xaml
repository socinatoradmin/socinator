<local:MessageConversationScraperConfigurationBase
    x:Class="LinkedDominatorUI.LDViews.Tools.Scraper.MessageConversationScraperConfiguration"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.Scraper"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
    xmlns:Control="http://metro.mahapps.com/winfx/xaml/controls"
    mc:Ignorable="d"
    x:Name="messageConversationScraperConfiguration"
    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction
                Command="{Binding LoadedCommand,ElementName=messageConversationScraperConfiguration}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Name="MainGrid">
        <StackPanel>
            <DHCustomControl:AccountGrowthModeHeader x:FieldModifier="public"
                                                     Name="AccountGrowthHeader"
                                                     VerticalAlignment="Top"
                                                     VideoTutorialLink="{Binding VideoTutorialLink}"
                                                     SelectionChangedCommand="{Binding SelectionChangedCommand,ElementName=messageConversationScraperConfiguration}"
                                                     SaveCommand="{Binding SaveConfigurationsCommand}" />
        </StackPanel>

        <Grid Margin="0,40,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="{DynamicResource LangKeyStatus}" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,10,0" />
                        <Controls:ToggleSwitch x:Name="TglStatus"
                                               IsChecked="{Binding MessageConversationScraperModel.IsAccountGrowthActive}"
                                               OnLabel="Active﻿"
                                               OffLabel="Stopped﻿"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction
                                        Command="{Binding StatusChangedCommand,ElementName=messageConversationScraperConfiguration}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Controls:ToggleSwitch>
                    </StackPanel>
                    <!--<StackPanel  Margin="5,15,0,5" Orientation="Horizontal" >
                        <CheckBox IsChecked="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}"/>
                        <Controls:DateTimePicker Margin="5,5,5,0" IsEnabled="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}" Controls:TextBoxHelper.UseFloatingWatermark="True"  SelectedDateFormat="Long"  Controls:TextBoxHelper.Watermark="Start Date"
                                                SelectedDate="{Binding  MessageConversationScraperModel.StartDateForMessageConversation, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True}"                       />
                        <Label HorizontalAlignment="Center" VerticalAlignment="Center" Content="{DynamicResource LangKeyTo}" />
                        <Controls:DateTimePicker Margin="5,5,5,0" IsEnabled="{Binding MessageConversationScraperModel.IsChkMessageDateMustBeInSpecificRange}" Controls:TextBoxHelper.UseFloatingWatermark="True"  SelectedDateFormat="Long"  Controls:TextBoxHelper.Watermark="End Date"
                                                SelectedDate="{Binding MessageConversationScraperModel.EndDateForMessageConversation, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True}"   />
                    </StackPanel>-->

                    <!-- source type-->

                    <StackPanel>
                        <Label Content="Attachments Message Source" FontWeight="Bold" Margin="5,10,0,0" />
                        <StackPanel Margin="15,15,0,5">
                            <RadioButton GroupName="MessageConversation" Margin="5" Content="All First Connections"
                                         IsChecked="{Binding MessageConversationScraperModel.IsAllFirstConnection}" />
                            <RadioButton GroupName="MessageConversation" Margin="5"
                                         Content="{DynamicResource LangKeyByCustomFirstConnectionList}"
                                         IsChecked="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList}" />

                            <StackPanel Margin="15,0,0,5"
                                        Visibility="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList,Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DHCustomControl:InputBoxControl Margin="25,5"
                                                                 InputText="{Binding MessageConversationScraperModel.UrlInput}"
                                                                 SaveCommand="{Binding SaveCustomGroupListCommand}"
                                                                 WaterMarkText="Enter First Connection Url(s)" />
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                    <!--<RadioButton GroupName="SourceType" Content="{DynamicResource LangKeyConnectionSources}" IsChecked="{Binding MessageConversationScraperModel.IsConnections}"  FontWeight="Bold" Margin="5,10,0,0" />
                    <StackPanel  Margin="15,0,0,5"  Visibility="{Binding MessageConversationScraperModel.IsConnections,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CheckBox Content="{DynamicResource LangKeyBySoftware}"   Margin="5" 
                                  IsChecked="{Binding MessageConversationScraperModel.IsCheckedBySoftware}" />

                        <CheckBox Content="{DynamicResource LangKeyOutsideSoftware}" Margin="5" 
                                  IsChecked="{Binding MessageConversationScraperModel.IsCheckedOutSideSoftware}" />
                        <CheckBox Content="{DynamicResource LangKeyCustomUsersList}"  Margin="5"
                                  IsChecked="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList}"/>
                        <DHCustomControl:InputBoxControl Margin="25,5" x:Name="CustomUserListInputBox" 
                                 InputText="{Binding MessageConversationScraperModel.UrlInput}"
                                 SaveCommand="{Binding SaveCustomUserListCommand}"
                                 WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}"
                                 Visibility="{Binding MessageConversationScraperModel.IsCheckedLangKeyCustomUserList,Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>-->

                    <!-- After JobConfiguration  Expander-->
                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">

                        <DHCustomControl:JobConfigControl
                            JobConfiguration="{Binding MessageConversationScraperModel.JobConfiguration}" />
                    </Expander>


                    <!--Other Configurations filter Expender-->
                    <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=HeaderControl}"  Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5">
                        <DHCustomControl:OtherConfig OtherConfigFilter="{Binding OtherConfigModel}"/>
                    </Expander>-->

                    <!-- After User Filters Expender-->


                    <!--Other Configurations filter Expander-->
                    <Expander IsExpanded="True" Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="Download Attachments" Margin="0,5,0,0"
                                      IsChecked="{Binding MessageConversationScraperModel.IsDonwloadAttachments}" />
                            <CheckBox Content="Delete All Conversations" Margin="0,5,0,0"
                                      IsChecked="{Binding MessageConversationScraperModel.IsDeleteAllConversations}" />
                            <!--<StackPanel Orientation="Horizontal">
                                <CheckBox Margin="0,5,0,0" x:Name="TakeMininumConnectionConversation" IsChecked="{Binding MessageConversationScraperModel.IsTakeMinimumConnectionConversation}" Content="{DynamicResource LangKeyTakeMinimumConnectionConversation}" />
                                <Control:NumericUpDown IsEnabled="{Binding MessageConversationScraperModel.IsTakeMinimumConnectionConversation}"  Margin="10,5,0,0"  Maximum="1999" Minimum="0" Value="{Binding MessageConversationScraperModel.NumberOfConnectionConversations}" x:Name="TakeMininumConnectionConversationTextBox" />
                            </StackPanel>-->
                        </StackPanel>
                    </Expander>

                    <!--Manage Blacklist Users  expander-->

                    <Expander Header="{DynamicResource LangKeyManageBlacklistedUsers}" Margin="5,5"
                              Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>

                            <CheckBox Content="{DynamicResource LangKeySkipBlacklistedUsers}" Margin="10,5"
                                      IsChecked="{Binding MessageConversationScraperModel.IsChkSkipBlackListedUser}" />

                            <StackPanel Margin="25,5"
                                        Visibility="{Binding MessageConversationScraperModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource LangKeyPrivateBlacklist}" Margin="5,0"
                                          IsChecked="{Binding MessageConversationScraperModel.IsChkPrivateBlackList}" />
                                <CheckBox Content="{DynamicResource LangKeyGroupBlacklist}" Margin="5,0"
                                          IsChecked="{Binding MessageConversationScraperModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</local:MessageConversationScraperConfigurationBase>