<UserControl x:Class="LinkedDominatorUI.LDViews.Tools.Tabs.SendGreetingsToConnectionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.Tabs"
             mc:Ignorable="d"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls">
    <Grid>
        <TabControl Name="SendGreetingsToConnectionsTabs" TabStripPlacement="Top"
                    Controls:TabControlHelper.Underlined="SelectedTabItem"
                    ItemContainerStyle="{StaticResource TabItemToolsStyle}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <UserControl Content="{Binding Content.Value}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>