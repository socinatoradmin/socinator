<local:LikeConfigurationBase x:Class="LinkedDominatorUI.LDViews.Tools.Engage.LikeConfiguration"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Tools.Engage"
                             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                             xmlns:DhCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
                             xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
                             xmlns:converters="clr-namespace:DominatorHouseCore.Converters;assembly=DominatorHouseCore"
                             mc:Ignorable="d"
                             x:Name="likeConfiguration"
                             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand,ElementName=likeConfiguration}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Name="MainGrid">
        <StackPanel>
            <DhCustomControl:AccountGrowthModeHeader x:FieldModifier="public" Name="AccountGrowthHeader"
                                                     VerticalAlignment="Top"
                                                     VideoTutorialLink="{Binding VideoTutorialLink}"
                                                     SelectionChangedCommand="{Binding SelectionChangedCommand,ElementName=likeConfiguration}"
                                                     SaveCommand="{Binding SaveConfigurationsCommand}" />
        </StackPanel>

        <Grid Margin="0,40,0,0" ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ScrollViewer>

                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10">
                        <TextBlock Text="{DynamicResource LangKeyStatus}" FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="10,0,10,0" />
                        <Controls:ToggleSwitch x:Name="TglStatus"
                                               IsChecked="{Binding LikeModel.IsAccountGrowthActive}"
                                               OnLabel="Active﻿" OffLabel="Stopped﻿"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Click">
                                    <i:InvokeCommandAction
                                        Command="{Binding StatusChangedCommand,ElementName=likeConfiguration}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Controls:ToggleSwitch>
                    </StackPanel>
                    <Expander Header="{DynamicResource LangKeySearchQuery}" IsExpanded="True" Margin="5">
                        <DhCustomControl:SearchQueryControl IsExpanded="True"
                                                            Name="LikeSearchControl"
                                                            ListQueryType="{Binding LikeModel.ListQueryType}"
                                                            ListQueryInfo="{Binding LikeModel.SavedQueries}"
                                                            AddQueryCommand="{Binding AddQueryCommand}"
                                                            CommandParameter="{Binding ElementName=likeConfiguration}"
                                                            CustomFilterCommand="{Binding CustomFilterCommand}"
                                                            DeleteQueryCommand="{Binding DeleteQueryCommand}"
                                                            DeleteMulipleCommand="{Binding DeleteMulipleCommand}" />
                    </Expander>
                    <StackPanel Orientation="Vertical">
                        <!-- After JobConfiguration  Expander-->
                        <Expander IsExpanded="True" Header="{DynamicResource LangKeyJobConfiguration}" Margin="5,5">
                            <DhCustomControl:JobConfigControl JobConfiguration="{Binding LikeModel.JobConfiguration}" />
                        </Expander>

                        <!-- After User Filters Expander-->

                        <Expander Header="{DynamicResource LangKeyUserFilters}" Margin="5,5" IsExpanded="True"
                                  Visibility="{Binding LikeModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl"
                                                                LDUserFilter="{Binding LikeModel.LDUserFilterModel}" />
                        </Expander>

                        <!--Manage Blacklist Users  expander-->

                        <Expander Header="{DynamicResource LangKeyManageBlacklistedUsers}" Margin="5,5"
                                  Visibility="{Binding LikeModel.IsEnableAdvancedUserMode,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <CheckBox Content="{DynamicResource LangKeySkipBlacklistedUsers}" Margin="10,5"
                                          IsChecked="{Binding LikeModel.IsChkSkipBlackListedUser}" />
                                <StackPanel Margin="25,5"
                                            Visibility="{Binding LikeModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Orientation="Horizontal">
                                    <CheckBox Content="{DynamicResource LangKeyPrivateBlacklist}" Margin="5,0"
                                              IsChecked="{Binding LikeModel.IsChkPrivateBlackList}" />
                                    <CheckBox Content="{DynamicResource LangKeyGroupBlacklist}" Margin="5,0"
                                              IsChecked="{Binding LikeModel.IsChkGroupBlackList}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- After Post Filter Expander-->

                        <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=LikeHeader}" Header="{DynamicResource LangKeyPostFilter}" Margin="5,5">
                            <LdCustomControl:PostFilterControl PostFilter="{Binding PostFilterModel}"/>
                        </Expander>-->

                        <!-- After Like Action Expander-->

                        <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=LikeHeader}" Header="{DynamicResource LangKeyAfterLikeAction}" Margin="5,5" >

                            <StackPanel>
                                <CheckBox Content="{DynamicResource LangKeyRelikePost}" Margin="5,5" IsChecked="{Binding ChkRelikePost}" />
                                <StackPanel Orientation="Horizontal" Margin="5,5" >
                                    <CheckBox Content="{DynamicResource LangKeyEnableLikeCommentsAfterPostsIsLiked}" IsChecked="{Binding ChkEnableLikeCommentsAfterPostIsLiked}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding ChkEnableLikeCommentsAfterPostIsLiked}" Value="{Binding CommentToBeLikeAfterEachLikedPost.StartValue}" Name="CommentToBeLikeAfterEachLikedPostStartValue" Minimum="0"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding ChkEnableLikeCommentsAfterPostIsLiked}" Value="{Binding CommentToBeLikeAfterEachLikedPost.EndValue}" Minimum="{Binding Value,ElementName=CommentToBeLikeAfterEachLikedPostStartValue}"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyAfterEachLikedPost}" />

                                </StackPanel>
                                <CheckBox Content="{DynamicResource LangKeyRemovePoorQualitySources}" Margin="5,5" IsChecked="{Binding ChkRemovePoorQualitySources}"/>
                                <StackPanel Orientation="Horizontal" Margin="5,5">
                                    <CheckBox Content="{DynamicResource LangKeyRemoveSourceIfFollowBackRatioIsLowerThan}" IsChecked="{Binding ChkRemoveSourceIfFollowRatioLower}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding ChkRemoveSourceIfFollowRatioLower}" Value="{Binding FollowBackRatio.StartValue}" Name="FollowBackRatioStartValue" 
                                                            Minimum="0"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyTo}" />
                                    <Controls:NumericUpDown Margin="5,5,5,0" IsEnabled="{Binding ChkRemoveSourceIfFollowRatioLower}" Value="{Binding FollowBackRatio.EndValue}" Minimum="{Binding Value,ElementName=FollowBackRatioStartValue}"/>
                                    <Label HorizontalAlignment="Center" VerticalAlignment="Center"  Content="{DynamicResource LangKeyLikes}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>-->

                    </StackPanel>
                </StackPanel>

            </ScrollViewer>

        </Grid>
    </Grid>
</local:LikeConfigurationBase>