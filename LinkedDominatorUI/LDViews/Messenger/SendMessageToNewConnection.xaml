<local:SendMessageToNewConnectionBase
    x:Class="LinkedDominatorUI.LDViews.Messenger.SendMessageToNewConnection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Messenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DHCustomControl:HeaderControl
                Name="HeaderControl"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Filter section  -->
        <Grid Margin="0,40,0,80" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">

                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeySourceFilter}"
                        FontWeight="Bold" />
                    <StackPanel Margin="15,0,0,5" Orientation="Horizontal">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyConnectedWithin}"
                            IsChecked="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}"
                            Minimum="0"
                            Value="{Binding SendMessageToNewConnectionModel.Days}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}"
                            Maximum="24"
                            Minimum="0"
                            Value="{Binding SendMessageToNewConnectionModel.Hours}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>
                    <!--<StackPanel Orientation="Horizontal" Margin="15,0,0,5">
                        <CheckBox Content="{DynamicResource LangKeyConnectedWithin}" Margin="5"
                                  IsChecked="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown Value="{Binding SendMessageToNewConnectionModel.Days}" Minimum="0"
                                                IsEnabled="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}" />

                        <Label Content="{DynamicResource LangKeyTo}" VerticalAlignment="Center"  />
                        <Controls:NumericUpDown Value="{Binding SendMessageToNewConnectionModel.Hours}" Minimum="0"
                                                Maximum="7"
                                                IsEnabled="{Binding SendMessageToNewConnectionModel.IsCheckedConnectedBefore}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                    </StackPanel>-->
                    <!--  Other  Message Expander  -->
                    <!--  Input Messages  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyInputMessageS}"
                        IsExpanded="True">
                        <!--<DHCustomControl:InputBoxControl Margin="30,5" x:Name="AutoReplyMessageInputBox" GetInputClick="AutoReplyMessageInputBox_OnGetInputClick"
                                                         Visibility="{Binding UserFilter.UserHasInvalidWord,Converter={StaticResource BooleanToVisibilityConverter}}"/>-->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox
                                    Name="chkSpintax"
                                    Margin="32,5,0,0"
                                    Content="{DynamicResource LangKeySpintax}"
                                    IsChecked="{Binding SendMessageToNewConnectionModel.IsChkSpintaxChecked}"
                                    ToolTip="Format : (Message 1|Message 2|Message 3|Message 4) Note: add any number of messages each separated by |"
                                    Visibility="Visible" />
                                <CheckBox
                                    Name="chkTag"
                                    Margin="10,5,0,0"
                                    Content="{DynamicResource LangKeyTag}"
                                    IsChecked="{Binding SendMessageToNewConnectionModel.IsChkTagChecked}"
                                    ToolTip="Format : &lt;First Name&gt;, &lt;Last Name&gt;, &lt;Full Name&gt;,&lt;Company Name&gt;,&lt;From First Name&gt;,&lt;From Last Name&gt;,&lt;From Full Name&gt;,&lt;From Company Name&gt;"
                                    Visibility="Visible" />

                            </StackPanel>
                            <StackPanel>
                                <DHCustomControl:MessageMediaControl
                                    Name="MessageMediaControl"
                                    AddMessagesCommand="{Binding AddMessagesCommand}"
                                    CommandParameter="{Binding ElementName=MessageMediaControl}"
                                    Messages="{Binding SendMessageToNewConnectionModel.ManageMessagesModel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                <DHCustomControl:ManageMediaMessages LstManageMessagesModel="{Binding SendMessageToNewConnectionModel.LstDisplayManageMessagesModel}" />
                            </StackPanel>

                            <!--<DHCustomControl:InputBoxControl Margin="30,5" x:Name="SendMessageInputBox"
                                                             InputText="{Binding Message}"
                                                             GetInputClick="SendMessageInputBox_OnGetInputClick"
                                                             Visibility="Visible"/>-->
                        </StackPanel>

                    </Expander>

                    <!--  After JobConfiguration  Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <DHCustomControl:JobConfigControl JobConfiguration="{Binding SendMessageToNewConnectionModel.JobConfiguration}" />
                        </ScrollViewer>

                    </Expander>

                    <!--  Other Configurations filter Expender  -->

                    <!--<Expander IsExpanded="True" Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5">
                        <DHCustomControl:OtherConfig OtherConfigFilter="{Binding OtherConfigModel}"/>
                    </Expander>-->


                    <!--  After User Filters Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyUserFilters}"
                        IsExpanded="True"
                        Visibility="{Binding SendMessageToNewConnectionModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding SendMessageToNewConnectionModel.LDUserFilterModel}" />
                    </Expander>

                    <!--  Other configuration  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True"
                        Visibility="{Binding UserScraperModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,0"
                                Content="View Profile"
                                IsChecked="{Binding SendMessageToNewConnectionModel.IsViewProfileUsingEmbeddedBrowser}" />
                            <StackPanel
                                Margin="25,0,0,0"
                                Orientation="Horizontal"
                                Visibility="{Binding SendMessageToNewConnectionModel.IsViewProfileUsingEmbeddedBrowser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Label VerticalAlignment="Center" Content="{DynamicResource LangKeyDelayBetween}" />
                                <Controls:NumericUpDown
                                    Name="delaybetweeneachviewstartvalue"
                                    Margin="5,5,5,0"
                                    Minimum="0"
                                    Value="{Binding SendMessageToNewConnectionModel.DelayBetweenViewProfileBeforeMessage.StartValue}" />
                                <Label
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource LangKeyTo}" />
                                <Controls:NumericUpDown
                                    Margin="5,5,5,0"
                                    Minimum="{Binding Value, ElementName=delaybetweeneachviewstartvalue}"
                                    Value="{Binding SendMessageToNewConnectionModel.DelayBetweenViewProfileBeforeMessage.EndValue}" />
                                <Label VerticalAlignment="Center" Content="Seconds After View Profile" />


                            </StackPanel>
                            <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                                <CheckBox
                                    Margin="0,5,0,0"
                                    Content="{DynamicResource LangKeyStopActivityOnContinuousFailsCount}"
                                    IsChecked="{Binding SendMessageToNewConnectionModel.IsStopSendMessageOnFailed}" />
                                <Controls:NumericUpDown
                                    Margin="5,0,5,5"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding SendMessageToNewConnectionModel.IsStopSendMessageOnFailed}"
                                    Minimum="1"
                                    Value="{Binding SendMessageToNewConnectionModel.StopSendMessageOnCount}" />
                            </StackPanel>
                            <!--<CheckBox Margin="10,0,0,0"
                                      Content="{DynamicResource LangKeySkipUsersAlreadyRecievedMessageFromSoftware}"
                                      IsChecked="{Binding SendMessageToNewConnectionModel.IsSkipUserAlreadyRecievedMessageFromSoftware}" />-->
                            <CheckBox
                                Margin="10,0,0,0"
                                Content="{DynamicResource LangKeySkipUsersAlreadyRecievedMessageFromOutsideSoftware}"
                                IsChecked="{Binding SendMessageToNewConnectionModel.IsSkipUserAlreadyRecievedMessageFromOutsideSoftware}" />
                        </StackPanel>
                    </Expander>

                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding SendMessageToNewConnectionModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding SendMessageToNewConnectionModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding SendMessageToNewConnectionModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding SendMessageToNewConnectionModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding SendMessageToNewConnectionModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0">
                <DHCustomControl:FooterControl
                    x:Name="SendMessageToNewConnectionFooter"
                    Height="96"
                    VerticalAlignment="Top"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=SendMessageToNewConnectionFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DHCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=SendMessageToNewConnectionFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoSendMessagetoNewConnection}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Grid>
</local:SendMessageToNewConnectionBase>