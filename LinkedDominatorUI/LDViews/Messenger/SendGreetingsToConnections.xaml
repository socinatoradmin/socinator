<local:SendGreetingsToConnectionsBase
    x:Class="LinkedDominatorUI.LDViews.Messenger.SendGreetingsToConnections"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Messenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{DynamicResource GabaritoSemiBold}"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DHCustomControl:HeaderControl
                Name="HeaderControl"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>


        <Grid Margin="0,40,0,80" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">
                    <Label
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeyGreetingOptions}"
                        FontWeight="Bold" />

                    <StackPanel Margin="15,0,0,5">
                        <CheckBox
                            x:Name="BirthdayGreeting"
                            Margin="5"
                            VerticalAlignment="Center"
                            Command="{Binding BirthdayGreetingCommand}"
                            CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                            Content="{DynamicResource LangKeyBirthdayGreeting}"
                            IsChecked="{Binding SendGreetingsToConnectionsModel.IsCheckedBirthdayGreeting}" />
                        <CheckBox
                            x:Name="NewJobGreeting"
                            Margin="5"
                            VerticalAlignment="Center"
                            Command="{Binding NewJobGreetingCommand}"
                            CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                            Content="{DynamicResource LangKeyNewJobGreeting}"
                            IsChecked="{Binding SendGreetingsToConnectionsModel.IsCheckedNewJobGreeting}" />
                        <CheckBox
                            x:Name="WorkAnniversaryGreeting"
                            Margin="5"
                            VerticalAlignment="Center"
                            Command="{Binding WorkAnniversaryGreetingCommand}"
                            CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                            Content="{DynamicResource LangKeyWorkAnniversaryGreeting}"
                            IsChecked="{Binding SendGreetingsToConnectionsModel.IsCheckedWorkAnniversaryGreeting}" />
                    </StackPanel>


                    <!--  Other  Message Expander  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyInputMessageS}"
                        IsExpanded="True">
                        <StackPanel>

                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox
                                        Name="chkSpintax"
                                        Margin="32,5,0,0"
                                        Content="{DynamicResource LangKeySpintax}"
                                        IsChecked="{Binding SendGreetingsToConnectionsModel.IsChkSpintaxChecked}"
                                        ToolTip="Format : (Message 1|Message 2|Message 3|Message 4) Note: add any number of messages each separated by |"
                                        Visibility="Visible" />
                                    <CheckBox
                                        Name="chkTag"
                                        Margin="10,5,0,0"
                                        Content="{DynamicResource LangKeyTag}"
                                        IsChecked="{Binding SendGreetingsToConnectionsModel.IsChkTagChecked}"
                                        ToolTip="Format : &lt;First Name&gt;, &lt;Last Name&gt;, &lt;Full Name&gt;,&lt;From First Name&gt;,&lt;From Last Name&gt;,&lt;From Full Name&gt;"
                                        Visibility="Visible" />

                                </StackPanel>

                            </StackPanel>
                            <StackPanel>
                                <DHCustomControl:MessagesControl
                                    Name="MessagesControl"
                                    AddMessagesCommand="{Binding AddMessagesCommand}"
                                    CommandParameter="{Binding ElementName=MessagesControl}"
                                    Messages="{Binding SendGreetingsToConnectionsModel.ManageMessagesModel}" />
                                <DHCustomControl:ManageMessages LstManageMessagesModel="{Binding SendGreetingsToConnectionsModel.LstDisplayManageMessagesModel}" />
                            </StackPanel>
                            <!--<DHCustomControl:InputBoxControl Margin="30,5" x:Name="SendMessageInputBox"
                                                             InputText="{Binding Message}"
                                                             GetInputClick="SendMessageInputBox_OnGetInputClick"
                                                             WaterMarkText="{DynamicResource LangKeySyntaxForGreetingInput}"
                                                             Visibility="Visible"/>-->
                        </StackPanel>
                    </Expander>

                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <DHCustomControl:JobConfigControl JobConfiguration="{Binding SendGreetingsToConnectionsModel.JobConfiguration}" />
                        </ScrollViewer>

                    </Expander>

                    <!--  Other Configurations filter Expender  -->
                    <!--<Expander IsExpanded="True"  Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5">
                        <DHCustomControl:OtherConfig OtherConfigFilter="{Binding OtherConfigModel}"/>
                    </Expander>-->


                    <!--  After User Filters Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyUserFilters}"
                        IsExpanded="True"
                        Visibility="{Binding SendGreetingsToConnectionsModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding SendGreetingsToConnectionsModel.LDUserFilterModel}" />
                    </Expander>

                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding SendGreetingsToConnectionsModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding SendGreetingsToConnectionsModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding SendGreetingsToConnectionsModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding SendGreetingsToConnectionsModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding SendGreetingsToConnectionsModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0">
                <DHCustomControl:FooterControl
                    x:Name="SendGreetingsToConnectionsFooter"
                    Height="96"
                    VerticalAlignment="Top"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=SendGreetingsToConnectionsFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DHCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=SendGreetingsToConnectionsFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoSendGreetingsToConnection}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>

    </Grid>
</local:SendGreetingsToConnectionsBase>