<local:AutoReplyToNewMessageBase
    x:Class="LinkedDominatorUI.LDViews.Messenger.AutoReplyToNewMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Messenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DHCustomControl:HeaderControl
                Name="HeaderControl"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Expander section  -->
        <Grid Margin="0,40,0,80" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">

                    <!--  Messages filter  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyMessageFilter}"
                        IsExpanded="True">
                        <StackPanel>
                            <!--<RadioButton Content="{DynamicResource LangKeyReplyToPendingMessages}"
                                         VerticalAlignment="Center" Margin="5"
                                         IsChecked="{Binding IsReplyToPendingMessagesChecked}"/>-->
                            <CheckBox
                                Name="CheckBox_ReplyToAllMessages"
                                Margin="5"
                                VerticalAlignment="Center"
                                Content="{DynamicResource LangKeyReplyToAllMessages}"
                                IsChecked="{Binding AutoReplyToNewMessageModel.IsReplyToAllMessagesChecked}" />
                            <CheckBox
                                Name="CheckBox_ReplyToMessagesThatContainSpecificWord"
                                Margin="5"
                                VerticalAlignment="Center"
                                Command="{Binding ReplyToMessagesThatContainSpecificWordCommand}"
                                CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                                Content="{DynamicResource LangKeyReplyToMessagesThatContainsSpecificWord}"
                                IsChecked="{Binding AutoReplyToNewMessageModel.IsReplyToMessagesThatContainSpecificWordChecked}" />

                            <DHCustomControl:InputBoxControl
                                x:Name="TextBox_SpecificWords"
                                Margin="30,5"
                                InputText="{Binding AutoReplyToNewMessageModel.SpecificWord}"
                                SaveCommand="{Binding SaveSpecificWordCommand}"
                                Visibility="{Binding AutoReplyToNewMessageModel.IsReplyToMessagesThatContainSpecificWordChecked, Converter={StaticResource BooleanToVisibilityConverter}}"
                                WaterMarkText="{DynamicResource LangKeySeparateTheWordsUsingCommaEGHiHello}" />
                            <CheckBox
                                Name="CheckBox_ReplyToAllUserMessagesWhodidnotReply"
                                Margin="5"
                                VerticalAlignment="Center"
                                Content="{DynamicResource LangKeyReplyToAllUserMessageWhodidnotreply}"
                                IsChecked="{Binding AutoReplyToNewMessageModel.IsReplyToAllUserMessagesWhodidnotReply}" />

                            <StackPanel Orientation="Horizontal" Visibility="{Binding AutoReplyToNewMessageModel.IsReplyToAllUserMessagesWhodidnotReply, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="20,5,0,5"
                                    Content="{DynamicResource LangKeyBySoftware}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsCheckedBySoftware}" />
                                <Label Padding="5" Content="{DynamicResource LangKeySendLastMessageNote}" />
                            </StackPanel>

                            <StackPanel
                                Margin="15,0,0,5"
                                Orientation="Horizontal"
                                Visibility="{Binding AutoReplyToNewMessageModel.IsReplyToAllUserMessagesWhodidnotReply, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5"
                                    Content="{DynamicResource LangKeyWhodidnotreplyfrom}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsCheckedLastSendMessageFrom}" />
                                <Controls:NumericUpDown
                                    IsEnabled="{Binding AutoReplyToNewMessageModel.IsCheckedLastSendMessageFrom}"
                                    Minimum="0"
                                    Value="{Binding AutoReplyToNewMessageModel.Days}" />
                                <Label Content="{DynamicResource LangKeyDays}" />
                                <Label Content="{DynamicResource LangKeyAnd}" />
                                <Controls:NumericUpDown
                                    IsEnabled="{Binding AutoReplyToNewMessageModel.IsCheckedLastSendMessageFrom}"
                                    Maximum="24"
                                    Minimum="0"
                                    Value="{Binding AutoReplyToNewMessageModel.Hours}" />
                                <Label Content="{DynamicResource LangKeyHours}" />
                            </StackPanel>
                            <StackPanel
                                Margin="15,0,0,0"
                                Orientation="Horizontal"
                                Visibility="{Binding AutoReplyToNewMessageModel.IsReplyToAllUserMessagesWhodidnotReply, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5"
                                    Content="{DynamicResource LangKeyIgnoreAlreadySentMessage}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsCheckedIgnoreAlreadySendMessage}" />
                            </StackPanel>
                            <!--<TextBox AcceptsReturn="True" Name="TextBox_SpecificWords" Height="80" HorizontalAlignment="Left" Width="300" Margin="10,5" Text="{Binding SpecificWord}"
                                     LostFocus="TextBox_SpecificWords_LostFocus"
                                     Visibility="{Binding IsReplyToMessagesThatContainSpecificWordChecked,
                                     Converter={StaticResource BooleanToVisibilityConverter}}" VerticalScrollBarVisibility="Auto"
                                     Controls:TextBoxHelper.Watermark="{DynamicResource LangKeyReplyToMessagesWaterMark﻿}"
                                     TextWrapping="Wrap"  Controls:TextBoxHelper.UseFloatingWatermark="True"/>-->

                        </StackPanel>

                    </Expander>

                    <!--  Input Messages  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyInputMessageS}"
                        IsExpanded="True">
                        <!--<DHCustomControl:InputBoxControl Margin="30,5" x:Name="AutoReplyMessageInputBox" GetInputClick="AutoReplyMessageInputBox_OnGetInputClick"
                                                         Visibility="{Binding UserFilter.UserHasInvalidWord,Converter={StaticResource BooleanToVisibilityConverter}}"/>-->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox
                                    Name="chkSpintax"
                                    Margin="32,5,0,0"
                                    Content="{DynamicResource LangKeySpintax}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsChkSpintaxChecked}"
                                    ToolTip="Format : (Message 1|Message 2|Message 3|Message 4) Note: add any number of messages each separated by |"
                                    Visibility="Visible" />
                                <CheckBox
                                    Name="chkTag"
                                    Margin="10,5,0,0"
                                    Content="{DynamicResource LangKeyTag}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsChkTagChecked}"
                                    ToolTip="Format : &lt;First Name&gt;, &lt;Last Name&gt;, &lt;Full Name&gt;,&lt;Company Name&gt;,&lt;From First Name&gt;,&lt;From Last Name&gt;,&lt;From Full Name&gt;,&lt;From Company Name&gt;"
                                    Visibility="Visible" />

                            </StackPanel>
                            <StackPanel>
                                <DHCustomControl:MessageMediaControl
                                    Name="MessageMediaControl"
                                    AddMessagesCommand="{Binding AddMessagesCommand}"
                                    CommandParameter="{Binding ElementName=MessageMediaControl}"
                                    Messages="{Binding AutoReplyToNewMessageModel.ManageMessagesModel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                <DHCustomControl:ManageMediaMessages LstManageMessagesModel="{Binding AutoReplyToNewMessageModel.LstDisplayManageMessagesModel}" />
                            </StackPanel>

                            <!--<DHCustomControl:InputBoxControl Margin="30,5" x:Name="SendMessageInputBox"
                                                             InputText="{Binding Message}"
                                                             GetInputClick="SendMessageInputBox_OnGetInputClick"
                                                             Visibility="Visible"/>-->
                        </StackPanel>

                    </Expander>

                    <!--  After JobConfiguration  Expender  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <DHCustomControl:JobConfigControl JobConfiguration="{Binding AutoReplyToNewMessageModel.JobConfiguration}" />
                        </ScrollViewer>
                    </Expander>

                    <!--  Other Configurations filter Expender  -->
                    <!--<Expander IsExpanded="{Binding IsExpanded,ElementName=HeaderControl}"  Header="{DynamicResource LangKeyOtherConfigurations}" Margin="5,5">
                        <DHCustomControl:OtherConfig OtherConfigFilter="{Binding OtherConfigModel}"/>
                    </Expander>-->

                    <!--  After User Filters Expender  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyUserFilters}"
                        IsExpanded="True"
                        Visibility="{Binding AutoReplyToNewMessageModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding AutoReplyToNewMessageModel.LDUserFilterModel}" />
                    </Expander>

                    <!--  Manage Blacklist Users  expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding AutoReplyToNewMessageModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding AutoReplyToNewMessageModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding AutoReplyToNewMessageModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding AutoReplyToNewMessageModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0">
                <DHCustomControl:FooterControl
                    x:Name="AutoReplyToNewMessageFooter"
                    Height="96"
                    VerticalAlignment="Top"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=AutoReplyToNewMessageFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DHCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=AutoReplyToNewMessageFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoReplyToNewMessage}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>


    </Grid>
</local:AutoReplyToNewMessageBase>