<local:BroadcastMessagesBase
    x:Class="LinkedDominatorUI.LDViews.Messenger.BroadcastMessages"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Messenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="BroadcastMessagesBase"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DHCustomControl:HeaderControl
                Name="HeaderControl"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Filter section  -->
        <Grid Margin="0,40,0,80" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">

                    <!--  source type  -->
                    <RadioButton
                        Margin="5,10,0,0"
                        Content="{DynamicResource LangKeyConnectionSources}"
                        FontWeight="Bold"
                        GroupName="SourceType"
                        IsChecked="{Binding BroadcastMessagesModel.IsConnections}" />
                    <StackPanel Margin="15,0,0,5" Visibility="{Binding BroadcastMessagesModel.IsConnections, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyBySoftware}"
                            IsChecked="{Binding BroadcastMessagesModel.IsCheckedBySoftware}" />

                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyOutsideSoftware}"
                            IsChecked="{Binding BroadcastMessagesModel.IsCheckedOutSideSoftware}" />
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyCustomUsersList}"
                            IsChecked="{Binding BroadcastMessagesModel.IsCheckedLangKeyCustomUserList}" />
                        <DHCustomControl:InputBoxControl
                            x:Name="CustomUserListInputBox"
                            Margin="25,5"
                            InputText="{Binding BroadcastMessagesModel.UrlInput}"
                            SaveCommand="{Binding SaveCustomUserListCommand}"
                            Visibility="{Binding BroadcastMessagesModel.IsCheckedLangKeyCustomUserList, Converter={StaticResource BooleanToVisibilityConverter}}"
                            WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}" />
                    </StackPanel>
                    <StackPanel
                        Margin="15,0,0,5"
                        Orientation="Horizontal"
                        Visibility="{Binding BroadcastMessagesModel.IsConnections, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CheckBox
                            Margin="5"
                            Content="{DynamicResource LangKeyConnectedWithin}"
                            IsChecked="{Binding BroadcastMessagesModel.IsCheckedConnectedBefore}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding BroadcastMessagesModel.IsCheckedConnectedBefore}"
                            Minimum="0"
                            Value="{Binding BroadcastMessagesModel.Days}" />
                        <Label Content="{DynamicResource LangKeyDays}" />
                        <Label Content="{DynamicResource LangKeyAnd}" />
                        <Controls:NumericUpDown
                            IsEnabled="{Binding BroadcastMessagesModel.IsCheckedConnectedBefore}"
                            Maximum="24"
                            Minimum="0"
                            Value="{Binding BroadcastMessagesModel.Hours}" />
                        <Label Content="{DynamicResource LangKeyHours}" />
                    </StackPanel>
                    <RadioButton
                        Margin="5,10,0,0"
                        Content="Group Sources :"
                        FontWeight="Bold"
                        GroupName="SourceType"
                        IsChecked="{Binding BroadcastMessagesModel.IsGroup}"
                        ToolTip="Send message to members of the group" />
                    <StackPanel Margin="15,0,0,5" Visibility="{Binding BroadcastMessagesModel.IsGroup, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DHCustomControl:InputBoxControl
                            Margin="25,5"
                            InputText="{Binding BroadcastMessagesModel.GroupUrlInput}"
                            SaveCommand="{Binding SaveCustomGroupListCommand}"
                            ToolTip="Send message to members of the group"
                            WaterMarkText="Enter Joined Group Urls" />
                    </StackPanel>

                    <RadioButton
                        Margin="5,10,0,10"
                        Content="{DynamicResource LangKeyOwnFollowers}"
                        FontWeight="Bold"
                        GroupName="SourceType"
                        IsChecked="{Binding BroadcastMessagesModel.IsFollower}"
                        ToolTip="Send message to own follower"
                        Visibility="Collapsed" />
                    <!--  messages manager Expander  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyInputMessageS}"
                        IsExpanded="True">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox
                                    Margin="32,5,0,0"
                                    Content="{DynamicResource LangKeySpintax}"
                                    IsChecked="{Binding BroadcastMessagesModel.IsChkSpintaxChecked}"
                                    ToolTip="{DynamicResource LangKeyMessageSpintaxFormat}"
                                    Visibility="Visible" />
                                <CheckBox
                                    Margin="10,5,0,0"
                                    Content="{DynamicResource LangKeyTag}"
                                    IsChecked="{Binding BroadcastMessagesModel.IsChkTagChecked}"
                                    ToolTip="Format : &lt;First Name&gt;, &lt;Last Name&gt;, &lt;Full Name&gt;,&lt;Company Name&gt;,&lt;From First Name&gt;,&lt;From Last Name&gt;,&lt;From Full Name&gt;,&lt;From Company Name&gt;"
                                    Visibility="Visible" />

                            </StackPanel>
                            <StackPanel>
                                <DHCustomControl:MessageMediaControl
                                    Name="MessageMediaControl"
                                    AddMessagesCommand="{Binding AddMessagesCommand}"
                                    CommandParameter="{Binding ElementName=MessageMediaControl}"
                                    Messages="{Binding BroadcastMessagesModel.ManageMessagesModel}"
                                    ShowMediaControl="Visible" />

                                <DHCustomControl:ManageMediaMessages LstManageMessagesModel="{Binding BroadcastMessagesModel.LstDisplayManageMessagesModel}" />

                                <!--<DHCustomControl:MessagesControl Messages="{Binding ManageMessagesModel}" AddMessagesToListChanged="MessagesControl_AddMessagesToListChanged"/>
                                <DHCustomControl:ManageMessages LstManageMessagesModel="{Binding LstDisplayManageMessagesModel}"  />-->
                            </StackPanel>

                            <!--<DHCustomControl:InputBoxControl Margin="30,5"
                                                             x:Name="SendMessageInputBox"
                                                             InputText="{Binding Message}"
                                                             GetInputClick="SendMessageInputBox_OnGetInputClick"
                                                             Visibility="Visible"/>-->
                        </StackPanel>
                    </Expander>

                    <!--  After JobConfiguration  Expander  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <DHCustomControl:JobConfigControl JobConfiguration="{Binding BroadcastMessagesModel.JobConfiguration}" />
                        </ScrollViewer>
                    </Expander>


                    <!--  User Filters Expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyUserFilters}"
                        IsExpanded="True"
                        Visibility="{Binding BroadcastMessagesModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <LdCustomControl:UserFiltersControl x:Name="UserFiltersControl" LDUserFilter="{Binding BroadcastMessagesModel.LDUserFilterModel}" />
                    </Expander>

                    <!--  Other Configurations filter Expander  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyOtherConfigurations}"
                        IsExpanded="True">
                        <StackPanel Orientation="Vertical">
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeyMessageUniqueUsersFromEachAccount}"
                                IsChecked="{Binding BroadcastMessagesModel.IsCampaignWiseUniqueChecked}" />
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeySkipUsersAlreadyRecievedMessageFromSoftware}"
                                IsChecked="{Binding BroadcastMessagesModel.IsSkipUserAlreadyRecievedMessageFromSoftware}" />
                            <CheckBox
                                Margin="0,5,0,0"
                                Content="{DynamicResource LangKeySkipUsersAlreadyRecievedMessageFromOutsideSoftware}"
                                IsChecked="{Binding BroadcastMessagesModel.IsSkipUserAlreadyRecievedMessageFromOutSideSoftware}" />
                            <CheckBox
                                Margin="0,5,0,0"
                                Content=" Save Failed Activity"
                                IsChecked="{Binding BroadcastMessagesModel.IsSaveFailedActivity}" />
                            <StackPanel Margin="0,0,0,0" Orientation="Horizontal">
                                <CheckBox
                                    Margin="0,5,0,0"
                                    Content="{DynamicResource LangKeyStopActivityOnContinuousFailsCount}"
                                    IsChecked="{Binding BroadcastMessagesModel.IsStopSendMessageOnFailed}" />
                                <Controls:NumericUpDown
                                    Margin="5,0,5,5"
                                    IsEnabled="{Binding BroadcastMessagesModel.IsStopSendMessageOnFailed}"
                                    Minimum="1"
                                    Value="{Binding BroadcastMessagesModel.StopSendMessageOnCount}" />
                            </StackPanel>
                        </StackPanel>

                    </Expander>

                    <!--  Manage Blacklist Users  Expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding BroadcastMessagesModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding BroadcastMessagesModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding BroadcastMessagesModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding BroadcastMessagesModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding BroadcastMessagesModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0">
                <DHCustomControl:FooterControl
                    x:Name="BrodCastMessageFooter"
                    Height="96"
                    VerticalAlignment="Top"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=BrodCastMessageFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DHCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=BrodCastMessageFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInAutoBroadcastMessages}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Grid>
</local:BroadcastMessagesBase>