<local:DeleteConversationsBase
    x:Class="LinkedDominatorUI.LDViews.Messenger.DeleteConversations"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:DHCustomControl="clr-namespace:DominatorUIUtility.CustomControl;assembly=DominatorUIUtility"
    xmlns:LdCustomControl="clr-namespace:LinkedDominatorUI.CustomControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LinkedDominatorUI.LDViews.Messenger"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="DeleteConversationsBase"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <!--  Header Section  -->
        <StackPanel VerticalAlignment="Top">
            <DHCustomControl:HeaderControl
                Name="HeaderControl"
                CampaignName="{Binding CampaignName}"
                CancelEditCommand="{Binding CancelEditCommand}"
                InfoCommand="{Binding InfoCommand}"
                IsCampaignNameEditable="{Binding IsEditCampaignName}"
                IsCancelEditVisible="{Binding CancelEditVisibility}" />
        </StackPanel>

        <!--  Filter section  -->
        <Grid Margin="0,40,0,80" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ScrollViewer>
                <StackPanel Orientation="Vertical">

                    <!--  source type  -->

                    <!--<StackPanel  Margin="15,0,0,5" >

                        <RadioButton GroupName="SourceType" Content="{DynamicResource LangKeyConnectionSources}"
                                     IsChecked="{Binding DeleteConversationsModel.IsAllUser}"  Margin="5,10,0,0" />

                        <RadioButton  GroupName="SourceType"  Content="{DynamicResource LangKeyCustomUsersList}"  Margin="5"
                                  IsChecked="{Binding DeleteConversationsModel.IsCustomUser}"/>
                        <DHCustomControl:InputBoxControl Margin="25,5" x:Name="CustomUserListInputBox"
                                 InputText="{Binding DeleteConversationsModel.UrlInput}"
                                 SaveCommand="{Binding SaveCustomUserListCommand}"
                                 WaterMarkText="{DynamicResource LangKeyEnterProfileUrlS}"
                                 Visibility="{Binding DeleteConversationsModel.IsCustomUser,Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>-->


                    <!--  After JobConfiguration  Expander  -->
                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyJobConfiguration}"
                        IsExpanded="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto">
                            <DHCustomControl:JobConfigControl JobConfiguration="{Binding DeleteConversationsModel.JobConfiguration}" />
                        </ScrollViewer>
                    </Expander>


                    <!--  Manage Blacklist Users  Expander  -->

                    <Expander
                        Margin="5,5"
                        Header="{DynamicResource LangKeyManageBlacklistedUsers}"
                        Visibility="{Binding DeleteConversationsModel.IsEnableAdvancedUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <CheckBox
                                Margin="10,5"
                                Content="{DynamicResource LangKeySkipBlacklistedUsers}"
                                IsChecked="{Binding DeleteConversationsModel.IsChkSkipBlackListedUser}" />
                            <StackPanel
                                Margin="25,5"
                                Orientation="Horizontal"
                                Visibility="{Binding DeleteConversationsModel.IsChkSkipBlackListedUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyPrivateBlacklist}"
                                    IsChecked="{Binding DeleteConversationsModel.IsChkPrivateBlackList}" />
                                <CheckBox
                                    Margin="5,0"
                                    Content="{DynamicResource LangKeyGroupBlacklist}"
                                    IsChecked="{Binding DeleteConversationsModel.IsChkGroupBlackList}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Create campaign and select account section  -->
        <StackPanel VerticalAlignment="Bottom">
            <Grid Margin="5,0">
                <DHCustomControl:FooterControl
                    x:Name="DeleteConversationsFooter"
                    Height="96"
                    VerticalAlignment="Top"
                    CampaignManager="{Binding CampaignButtonContent}"
                    CreateCampaignCommand="{Binding CreateCampaignCommand}"
                    NoOfAccountsSelected="{Binding SelectedAccountCount, Mode=TwoWay}"
                    SelectAccountCommand="{Binding SelectAccountCommand}" />
            </Grid>
        </StackPanel>

        <!--  Help section  -->
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Name="HelpFlyout"
                Width="300"
                Background="{DynamicResource AccentBaseColorBrush}"
                BorderBrush="Black"
                BorderThickness="2"
                DataContext="{Binding ElementName=DeleteConversationsFooter, Path=DataContext}"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Header="{DynamicResource LangKeyModuleDescription}"
                IsOpen="{Binding IsOpen, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                Position="Right"
                Theme="Accent"
                Visibility="Collapsed">

                <DHCustomControl:HelpControl
                    ContactSupportLink="{Binding ContactSupportLink}"
                    DataContext="{Binding ElementName=DeleteConversationsFooter, Path=DataContext}"
                    KnowledgeBaseLink="{Binding KnowledgeBaseLink}"
                    ModuleDescription="{DynamicResource LangKeyModuleDescriptionLinkedInDeleteConversation}"
                    VideoTutorial="{Binding VideoTutorialLink}" />
            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Grid>
</local:DeleteConversationsBase>